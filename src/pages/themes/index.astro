---
import { getCollection } from 'astro:content';
import Base from '~/layouts/Base.astro';
import ThemeCard from '~/components/theme/ThemeCard.astro';

const themes = (await getCollection('themes'))
  .sort((a, b) => a.data.order - b.data.order);

const categories = [
  { value: 'all', label: 'All' },
  { value: 'editor', label: 'Editor' },
  { value: 'terminal', label: 'Terminal' },
  { value: 'notes', label: 'Notes' },
  { value: 'browser', label: 'Browser' },
  { value: 'chat', label: 'Chat' },
  { value: 'productivity', label: 'Productivity' },
];

const presentCategories = new Set(themes.map((t) => t.data.category));
const visibleCategories = categories.filter(
  (c) => c.value === 'all' || presentCategories.has(c.value as any),
);

const statuses = [
  { value: 'all', label: 'All' },
  { value: 'stable', label: 'Stable' },
  { value: 'beta', label: 'Beta' },
  { value: 'planned', label: 'Planned' },
];
---

<Base
  title="Themes"
  description="All Slatewave themes — every surface where the Slatewave palette lives."
>
  <section class="section">
    <div class="container">
      <header class="head">
        <p class="eyebrow">Themes</p>
        <h1>Every surface, one palette.</h1>
        <p class="lede">
          Pick the tool you live in. Every theme below is generated from the
          same Slatewave palette, tuned for that surface.
        </p>
      </header>

      <form class="filters" id="theme-filters" aria-label="Filter themes">
        <fieldset>
          <legend>Category</legend>
          <div class="chips">
            {visibleCategories.map((c, i) => (
              <label class="chip">
                <input
                  type="radio"
                  name="category"
                  value={c.value}
                  checked={i === 0}
                />
                <span>{c.label}</span>
              </label>
            ))}
          </div>
        </fieldset>

        <fieldset>
          <legend>Status</legend>
          <div class="chips">
            {statuses.map((s, i) => (
              <label class="chip">
                <input
                  type="radio"
                  name="status"
                  value={s.value}
                  checked={i === 0}
                />
                <span>{s.label}</span>
              </label>
            ))}
          </div>
        </fieldset>
      </form>

      <p class="count" id="theme-count" aria-live="polite">
        Showing {themes.length} {themes.length === 1 ? 'theme' : 'themes'}
      </p>

      <ul class="grid" id="theme-grid">
        {themes.map((theme) => (
          <li
            class="theme-item"
            data-category={theme.data.category}
            data-status={theme.data.status}
          >
            <ThemeCard theme={theme} />
          </li>
        ))}
      </ul>

      <p class="empty" id="theme-empty" hidden>
        No themes match these filters yet.
      </p>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('theme-filters') as HTMLFormElement | null;
  const items = document.querySelectorAll<HTMLElement>('.theme-item');
  const empty = document.getElementById('theme-empty');
  const count = document.getElementById('theme-count');
  const total = items.length;

  const update = () => {
    if (!form) return;
    const data = new FormData(form);
    const cat = String(data.get('category') ?? 'all');
    const status = String(data.get('status') ?? 'all');
    let visible = 0;
    items.forEach((item) => {
      const matchCat = cat === 'all' || item.dataset.category === cat;
      const matchStatus = status === 'all' || item.dataset.status === status;
      const show = matchCat && matchStatus;
      item.hidden = !show;
      if (show) visible += 1;
    });
    if (empty) empty.hidden = visible !== 0;
    if (count) {
      count.textContent =
        visible === total
          ? `Showing all ${total} ${total === 1 ? 'theme' : 'themes'}`
          : `Showing ${visible} of ${total} ${total === 1 ? 'theme' : 'themes'}`;
    }
  };

  form?.addEventListener('change', update);
</script>

<style>
  .section {
    padding-block: var(--space-12) var(--space-16);
  }

  .head {
    margin-bottom: var(--space-8);
    max-width: 44rem;
  }

  .head h1 {
    margin-top: var(--space-3);
    font-size: clamp(2rem, 4vw, var(--fs-2xl));
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .lede {
    margin-top: var(--space-4);
    color: var(--fg-muted);
    font-size: var(--fs-md);
  }

  .filters {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
    padding: var(--space-4) var(--space-5);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-4);
  }

  .filters fieldset {
    border: 0;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-2);
  }

  .filters legend {
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    font-weight: 600;
  }

  .chips {
    display: inline-flex;
    background: var(--bg-inset);
    padding: 3px;
    border-radius: var(--radius-md);
    gap: 2px;
    flex-wrap: wrap;
  }

  .chip {
    cursor: pointer;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    font-size: var(--fs-sm);
    color: var(--fg-muted);
    transition: background 120ms ease, color 120ms ease;
  }

  .chip:hover {
    color: var(--fg-default);
  }

  .chip input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .chip:has(input:checked) {
    background: var(--bg-raised);
    color: var(--fg-default);
    box-shadow: 0 0 0 1px var(--border-strong);
  }

  .chip:has(input:focus-visible) {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
  }

  .count {
    margin-bottom: var(--space-5);
    color: var(--fg-subtle);
    font-size: var(--fs-xs);
    letter-spacing: 0.04em;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-5);
    list-style: none;
    padding: 0;
  }

  .empty {
    padding: var(--space-8);
    text-align: center;
    color: var(--fg-subtle);
    background: var(--bg-raised);
    border: 1px dashed var(--border);
    border-radius: var(--radius-md);
  }
</style>
