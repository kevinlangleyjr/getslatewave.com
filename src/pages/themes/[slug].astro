---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Base from '~/layouts/Base.astro';
import Badge from '~/components/ui/Badge.astro';
import CodePreview from '~/components/previews/CodePreview.astro';
import TerminalPreview from '~/components/previews/TerminalPreview.astro';
import { fetchRepoMeta } from '~/lib/github';
import { relativeTime, absoluteDate, formatStars } from '~/lib/format';

export async function getStaticPaths() {
  const themes = await getCollection('themes', ({ data }) => data.status !== 'planned');
  return themes.map((theme) => ({
    params: { slug: theme.data.slug },
    props: { theme },
  }));
}

interface Props {
  theme: CollectionEntry<'themes'>;
}

const { theme } = Astro.props;
const { data } = theme;
const { Content } = await render(theme);

const accentStyle = data.accent ? `--page-accent: ${data.accent}` : undefined;
const primaryInstall = data.install?.[0];

const slugifyMethod = (label: string) =>
  label.toLowerCase().trim().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
const slugSegment = data.slug.replace(/-/g, '_');

const meta = await fetchRepoMeta(data.repo.owner, data.repo.name);
---

<Base title={data.name} description={data.summary}>
  <article class="theme-page" style={accentStyle}>
    <header class="hero">
      <div class="container">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/themes/">Themes</a>
          <span aria-hidden="true">/</span>
          <span>{data.shortName}</span>
        </nav>
        <p class="eyebrow">{data.category}</p>
        <h1>{data.name}</h1>
        <p class="tagline">{data.tagline}</p>
        <div class="meta">
          <Badge tone={data.status}>{data.status}</Badge>
          <a
            href={data.repo.url}
            rel="noopener"
            target="_blank"
            class="repo-link"
            data-simple-event={`install_${slugSegment}_repo`}
          >
            {data.repo.owner}/{data.repo.name} ↗
          </a>
          {data.links.marketplace && (
            <a
              href={data.links.marketplace}
              rel="noopener"
              target="_blank"
              class="repo-link"
              data-simple-event={`install_${slugSegment}_marketplace`}
            >
              Marketplace ↗
            </a>
          )}
        </div>

        <div class="hero-actions" aria-label="Theme actions">
          <a
            class="btn btn-primary"
            href="#install-heading"
            data-simple-event={`cta_theme_install_jump_${slugSegment}`}
          >
            <span>{primaryInstall?.command ? `Install with ${primaryInstall.label}` : 'View install steps'}</span>
            <span aria-hidden="true">↓</span>
          </a>
          <a class="btn btn-ghost" href="/themes/" data-simple-event="cta_theme_browse_all">Browse all themes</a>
        </div>

        {meta && (meta.stars > 0 || meta.latestRelease || meta.pushedAt) && (
          <dl class="stats" aria-label="Repository activity">
            {meta.stars > 0 && (
              <div class="stat">
                <dt>Stars</dt>
                <dd>★ {formatStars(meta.stars)}</dd>
              </div>
            )}
            {meta.latestRelease && (
              <div class="stat">
                <dt>Latest release</dt>
                <dd>
                  <a
                    href={meta.latestRelease.url}
                    rel="noopener"
                    target="_blank"
                    title={absoluteDate(meta.latestRelease.publishedAt)}
                  >
                    {meta.latestRelease.tag}
                  </a>
                  <span class="muted"> · {relativeTime(meta.latestRelease.publishedAt)}</span>
                </dd>
              </div>
            )}
            {meta.pushedAt && (
              <div class="stat">
                <dt>Last commit</dt>
                <dd>{relativeTime(meta.pushedAt)}</dd>
              </div>
            )}
          </dl>
        )}
      </div>
    </header>

    <section class="section">
      <div class="container narrow">
        {data.preview.kind === 'code' && (
          <CodePreview code={data.preview.sample} language={data.preview.language} />
        )}
        {data.preview.kind === 'terminal' && (
          <TerminalPreview prompt={data.preview.prompt} lines={data.preview.lines} />
        )}
        {data.preview.kind === 'image' && (
          <figure class="sw-frame image-preview">
            <img src={data.preview.image.src} alt={data.preview.alt} loading="eager" />
          </figure>
        )}
      </div>
    </section>

    <section class="section">
      <div class="container narrow prose">
        <h2>About this theme</h2>
        <p class="summary">{data.summary}</p>
        <Content />
      </div>
    </section>

    <section class="section install-section" id="install" data-theme-slug={data.slug}>
      <div class="container narrow">
        <h2 id="install-heading">Install</h2>
        <ul class="install-list">
          {data.install.map((method) => (
            <li class="install-item">
              <header>
                <h3>{method.label}</h3>
                {method.link && (
                  <a
                    href={method.link}
                    rel="noopener"
                    target="_blank"
                    data-simple-event={`install_${slugSegment}_external_${slugifyMethod(method.label)}`}
                  >
                    Open ↗
                  </a>
                )}
              </header>
              {method.description && <p class="muted">{method.description}</p>}
              {method.command && (
                <div class="install-command">
                  <pre class="install-cmd"><code>{method.command}</code></pre>
                  <button
                    type="button"
                    class="copy-command"
                    data-copy-command={method.command}
                    data-method-id={slugifyMethod(method.label)}
                    data-method-label={method.label}
                    aria-label={`Copy ${method.label} install command`}
                  >
                    Copy
                  </button>
                </div>
              )}
              {method.steps && (
                <ol>
                  {method.steps.map((step) => <li>{step}</li>)}
                </ol>
              )}
            </li>
          ))}
        </ul>
      </div>
    </section>
  </article>
</Base>

<script>
  import { trackEvent } from '~/lib/analytics';

  const installSection = document.querySelector<HTMLElement>('.install-section');
  const themeSlug = installSection?.dataset.themeSlug ?? 'unknown';

  const copyButtons = document.querySelectorAll<HTMLButtonElement>('[data-copy-command]');

  const selectCommand = (button: HTMLButtonElement) => {
    const command = button
      .closest<HTMLElement>('.install-command')
      ?.querySelector('code');
    if (!command) return false;

    const range = document.createRange();
    range.selectNodeContents(command);
    const selection = window.getSelection();
    selection?.removeAllRanges();
    selection?.addRange(range);
    return true;
  };

  copyButtons.forEach((button) => {
    const original = button.textContent ?? 'Copy';
    button.addEventListener('click', async () => {
      const command = button.dataset.copyCommand;
      if (!command) return;

      const methodId = button.dataset.methodId ?? 'unknown';
      const methodLabel = button.dataset.methodLabel ?? methodId;

      const slugSegment = themeSlug.replace(/-/g, '_');

      try {
        await navigator.clipboard.writeText(command);
        button.textContent = 'Copied';
        button.dataset.copied = 'true';
        trackEvent(`install_${slugSegment}_copy_command_${methodId}`, {
          method: methodLabel,
        });
        window.setTimeout(() => {
          button.textContent = original;
          delete button.dataset.copied;
        }, 1800);
      } catch {
        button.textContent = selectCommand(button) ? 'Selected' : 'Select command';
        trackEvent(`install_${slugSegment}_copy_command_fallback_${methodId}`, {
          method: methodLabel,
        });
        window.setTimeout(() => {
          button.textContent = original;
        }, 1800);
      }
    });
  });
</script>

<style>
  .theme-page {
    --page-accent: var(--accent);
  }

  .hero {
    padding-block: var(--space-16) var(--space-10);
    position: relative;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .hero {
      padding-block: var(--space-10) var(--space-6);
    }
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: -20% 40% 0 -10%;
    background: radial-gradient(50% 50% at 50% 50%, color-mix(in oklab, var(--page-accent) 20%, transparent), transparent 70%);
    filter: blur(80px);
    pointer-events: none;
  }

  .hero .container {
    position: relative;
  }

  .breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    color: var(--fg-subtle);
    font-size: var(--fs-sm);
  }

  .breadcrumb a:hover {
    color: var(--page-accent);
  }

  .hero h1 {
    margin-top: var(--space-3);
    font-size: clamp(2rem, 4vw, var(--fs-2xl));
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .tagline {
    margin-top: var(--space-4);
    color: var(--fg-muted);
    font-size: var(--fs-md);
    max-width: 42rem;
  }

  .meta {
    margin-top: var(--space-6);
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .repo-link {
    font-size: var(--fs-sm);
    color: var(--fg-muted);
    font-family: var(--font-mono);
  }

  .repo-link:hover {
    color: var(--page-accent);
  }

  .hero-actions {
    margin-top: var(--space-6);
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-md);
    font-size: var(--fs-sm);
    font-weight: 600;
    border: 1px solid transparent;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.14) inset;
    transition:
      background 120ms ease,
      border-color 120ms ease,
      box-shadow 120ms ease,
      color 120ms ease,
      transform 120ms ease;
  }

  .btn-primary {
    background: var(--page-accent);
    color: var(--accent-ink);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.35) inset,
      0 10px 24px color-mix(in oklab, var(--page-accent) 20%, transparent);
  }

  .btn-primary:hover {
    background: color-mix(in oklab, var(--page-accent) 85%, white);
    color: var(--accent-ink);
    transform: translateY(-1px);
  }

  .btn-ghost {
    background: transparent;
    color: var(--fg-default);
    border-color: var(--border-strong);
  }

  .btn-ghost:hover {
    background: var(--bg-raised);
    color: var(--fg-default);
  }

  .stats {
    margin-top: var(--space-6);
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
    padding: var(--space-4) var(--space-5);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-size: var(--fs-sm);
  }

  .stat {
    display: grid;
    gap: 2px;
  }

  .stat dt {
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    font-weight: 600;
  }

  .stat dd {
    margin: 0;
    color: var(--fg-default);
    font-family: var(--font-mono);
  }

  .stat dd a {
    color: var(--page-accent);
  }

  .stat .muted {
    color: var(--fg-subtle);
    font-family: var(--font-sans);
  }

  .section {
    padding-block: var(--space-8);
  }

  .install-section {
    padding-bottom: var(--space-16);
  }

  #install-heading {
    scroll-margin-top: calc(var(--space-24) + var(--space-16));
  }

  .narrow {
    max-width: 48rem;
  }

  .image-preview img {
    width: 100%;
    height: auto;
    display: block;
  }

  .prose h2 {
    font-size: var(--fs-lg);
    font-weight: 600;
    margin-bottom: var(--space-3);
  }

  .prose p {
    color: var(--fg-muted);
    margin-top: var(--space-3);
  }

  .prose .summary {
    font-size: var(--fs-md);
    color: var(--fg-default);
  }

  .install-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-5);
  }

  .install-item {
    min-width: 0;
    padding: var(--space-5);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .install-item header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }

  .install-item h3 {
    font-size: var(--fs-md);
    font-weight: 600;
  }

  .install-item header a {
    font-size: var(--fs-sm);
    color: var(--page-accent);
  }

  .install-command {
    margin-top: var(--space-3);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: stretch;
    padding: var(--space-3) var(--space-4);
    background: var(--bg-inset);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    gap: var(--space-3);
  }

  .install-cmd {
    overflow-x: auto;
    max-width: 100%;
    font-size: var(--fs-sm);
    align-self: center;
  }

  .install-cmd code {
    white-space: pre;
  }

  .copy-command {
    align-self: center;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    background: color-mix(in oklab, var(--page-accent) 18%, transparent);
    color: var(--page-accent);
    border: 1px solid color-mix(in oklab, var(--page-accent) 35%, transparent);
    font-size: var(--fs-xs);
    font-weight: 600;
    transition: background 120ms ease, color 120ms ease;
  }

  .copy-command:hover,
  .copy-command[data-copied='true'] {
    background: var(--page-accent);
    color: var(--accent-ink);
  }

  @media (max-width: 560px) {
    .install-command {
      grid-template-columns: 1fr;
    }

    .copy-command {
      justify-self: start;
    }
  }

  .install-item ol {
    margin-top: var(--space-3);
    padding-left: var(--space-5);
    color: var(--fg-muted);
    font-size: var(--fs-sm);
    display: grid;
    gap: var(--space-2);
  }

  .install-item ol li {
    overflow-wrap: anywhere;
  }

  .muted {
    color: var(--fg-muted);
    font-size: var(--fs-sm);
  }

  h2 {
    font-size: var(--fs-lg);
    font-weight: 600;
  }
</style>
