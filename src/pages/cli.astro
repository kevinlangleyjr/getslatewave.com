---
import { getCollection } from 'astro:content';
import Base from '~/layouts/Base.astro';
import TerminalPreview from '~/components/previews/TerminalPreview.astro';
import { fetchRepoMeta } from '~/lib/github';
import { relativeTime, absoluteDate, formatStars } from '~/lib/format';

const cliRepo = await fetchRepoMeta('kevinlangleyjr', 'slatewave-cli');

const supportedThemes = (
  await getCollection('themes', ({ data }) => data.status !== 'planned' && !!data.cliSlug)
).sort((a, b) => a.data.shortName.localeCompare(b.data.shortName));

const installCommand = `brew tap kevinlangleyjr/slatewave\nbrew install slatewave`;

const commands: { name: string; description: string }[] = [
  { name: 'slatewave init', description: 'Interactive setup wizard — detect the tools on this machine, multi-select what to install, and run the install through a live dashboard.' },
  { name: 'slatewave browse', description: 'Interactive TUI list with filter, install, and uninstall — ↑/↓ to navigate, / to filter, i / u to install or uninstall the focused row.' },
  { name: 'slatewave list', description: 'Every theme in the family, with ● / ○ markers showing which ones are installed.' },
  { name: 'slatewave install <theme>', description: 'Install and activate one theme. Add --all to install every shipping theme, or --category=editor to install a category.' },
  { name: 'slatewave install --interactive', description: 'Live progress dashboard instead of streamed steps — useful for --all or --category.' },
  { name: 'slatewave install <theme> --dry-run', description: 'Preview the install plan without writing anything.' },
  { name: 'slatewave update <theme>', description: 'Re-fetch curl assets and git pull clones. --all updates every installed theme.' },
  { name: 'slatewave uninstall <theme>', description: 'Reverse files, restore backups from before the install, and remove appended shell-rc lines.' },
  { name: 'slatewave status [theme]', description: 'Show the install footprint and paths for one theme — or every installed theme.' },
  { name: 'slatewave doctor', description: 'Diagnose drift across installed themes (read-only). Add --fix to interactively remediate stale, missing-tool, or orphan rows.' },
];

const designRules: { title: string; body: string }[] = [
  {
    title: 'It does not install the underlying tool',
    body: 'If bat is not on $PATH, slatewave install bat errors. Install your tool via brew or your package manager first — this is a theme installer, one job at a time.',
  },
  {
    title: 'Detection before action',
    body: 'Every manifest declares a detect_command (bat --version, btop --version). Failing detection bails before any filesystem changes happen.',
  },
  {
    title: 'Idempotent activates',
    body: 'shell-rc lines and ini-key edits no-op when already in place. Re-running an install on a clean install changes nothing.',
  },
  {
    title: 'Backups before edits',
    body: 'Any manifest whose activate type replaces an existing config line writes a .slatewave.<timestamp>.bak first. slatewave uninstall restores from it.',
  },
];

// TODO: replace this hardcoded approximation with an asciinema-player embed
// pointing at /cli/init-demo.cast once the recording is captured.
const initDemoLines = [
  { kind: 'input' as const, prompt: true, text: 'slatewave init' },
  { kind: 'info' as const, text: 'Detecting Slatewave-supported tools on this machine…' },
  { kind: 'output' as const, text: '  ● bat            (v0.24.0)' },
  { kind: 'output' as const, text: '  ● btop           (v1.4.0)' },
  { kind: 'output' as const, text: '  ● ghostty        (v1.0.1)' },
  { kind: 'output' as const, text: '  ● vscode         (1.96.0)' },
  { kind: 'output' as const, text: '  ○ logseq         (not detected — skipped)' },
  { kind: 'info' as const, text: '? Install Slatewave for which tools? (space to toggle, enter to confirm)' },
  { kind: 'output' as const, text: '  ◆ bat   ◆ btop   ◆ ghostty   ◆ vscode' },
  { kind: 'ok' as const, text: '✓ bat       installed (curl → ~/.config/bat/themes)' },
  { kind: 'ok' as const, text: '✓ btop      installed (curl → ~/.config/btop/themes)' },
  { kind: 'ok' as const, text: '✓ ghostty   installed (clone → ~/.config/ghostty/themes/slatewave)' },
  { kind: 'ok' as const, text: '✓ vscode    installed (code --install-extension)' },
  { kind: 'info' as const, text: '4 themes installed · 0 errors · run `slatewave status` to view' },
];
---

<Base
  title="Slatewave CLI"
  description="The family installer for Slatewave themes — one CLI to install, activate, update, and uninstall every theme. brew install kevinlangleyjr/slatewave/slatewave."
  ogImage="/og/cli.png"
>
  <article class="cli-page">
    <header class="hero">
      <div class="container">
        <p class="eyebrow">CLI</p>
        <h1>One command.<br />Every theme.</h1>
        <p class="tagline">
          The family installer for Slatewave. One CLI to install, activate,
          update, and uninstall every theme — backed by per-theme manifests,
          idempotent activates, and clean uninstalls.
        </p>

        <div class="install-command">
          <pre class="install-cmd"><code>{installCommand}</code></pre>
          <button
            type="button"
            class="copy-command"
            data-copy-command={installCommand}
            aria-label="Copy install command"
          >
            Copy
          </button>
        </div>

        <div class="hero-actions">
          <a
            class="btn btn-ghost"
            href="https://github.com/kevinlangleyjr/slatewave-cli"
            rel="noopener"
            target="_blank"
            data-simple-event="cta_cli_hero_github"
          >
            View on GitHub
          </a>
          <a
            class="btn btn-link"
            href="https://github.com/kevinlangleyjr/homebrew-slatewave"
            rel="noopener"
            target="_blank"
            data-simple-event="cta_cli_hero_tap"
          >
            Homebrew tap →
          </a>
        </div>

        {cliRepo && (cliRepo.stars > 0 || cliRepo.latestRelease) && (
          <dl class="stats" aria-label="CLI repository activity">
            {cliRepo.stars > 0 && (
              <div class="stat">
                <dt>Stars</dt>
                <dd>★ {formatStars(cliRepo.stars)}</dd>
              </div>
            )}
            {cliRepo.latestRelease && (
              <div class="stat">
                <dt>Latest release</dt>
                <dd>
                  <a
                    href={cliRepo.latestRelease.url}
                    rel="noopener"
                    target="_blank"
                    title={absoluteDate(cliRepo.latestRelease.publishedAt)}
                  >
                    {cliRepo.latestRelease.tag}
                  </a>
                  <span class="muted"> · {relativeTime(cliRepo.latestRelease.publishedAt)}</span>
                </dd>
              </div>
            )}
            {cliRepo.pushedAt && (
              <div class="stat">
                <dt>Last commit</dt>
                <dd>{relativeTime(cliRepo.pushedAt)}</dd>
              </div>
            )}
          </dl>
        )}
      </div>
    </header>

    <section class="section before-after">
      <div class="container narrow">
        <header class="section-head">
          <p class="eyebrow">What it replaces</p>
          <h2>Stop pasting install rituals.</h2>
          <p class="section-lede">
            Per-theme manifests encode the install paths, activation steps,
            and post-hooks for every tool — so you stop curating shell snippets.
          </p>
        </header>

        <div class="comparison">
          <div class="comparison-col">
            <p class="comparison-label">Before</p>
            <pre class="snippet"><code>{`mkdir -p "$(bat --config-dir)/themes" \\
 && curl -fsSL https://raw.githubusercontent.com/kevinlangleyjr/bat-slatewave/main/Slatewave.tmTheme \\
      -o "$(bat --config-dir)/themes/Slatewave.tmTheme" \\
 && bat cache --build \\
 && echo 'export BAT_THEME=Slatewave' >> ~/.zshrc`}</code></pre>
          </div>
          <div class="comparison-col">
            <p class="comparison-label comparison-after">After</p>
            <pre class="snippet snippet-after"><code>slatewave install bat</code></pre>
          </div>
        </div>
      </div>
    </section>

    <section class="section demo-section">
      <div class="container narrow">
        <header class="section-head">
          <p class="eyebrow">First run</p>
          <h2>Detect, pick, install.</h2>
          <p class="section-lede">
            <code>slatewave init</code> walks you through the family — only the
            tools already on this machine are surfaced, and only what you check
            actually gets installed.
          </p>
        </header>

        <TerminalPreview lines={initDemoLines} directory="~" branch="main" />
        <!-- TODO: Update with a live <code>asciinema</code> recording here once captured. -->
      </div>
    </section>

    <section class="section commands-section">
      <div class="container narrow">
        <header class="section-head">
          <p class="eyebrow">Commands</p>
          <h2>The full surface area.</h2>
          <p class="section-lede">
            Every command is fully completion-aware in <code>zsh</code>,
            <code>bash</code>, and <code>fish</code> —
            theme names autocomplete on <code>install</code>, only installed
            themes autocomplete on <code>uninstall</code>.
          </p>
        </header>

        <ul class="commands-list">
          {commands.map((cmd) => (
            <li class="command-item">
              <code class="command-name">{cmd.name}</code>
              <p class="command-desc">{cmd.description}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section rules-section">
      <div class="container narrow">
        <header class="section-head">
          <p class="eyebrow">Design rules</p>
          <h2>What it will and won't do.</h2>
          <p class="section-lede">
            The CLI is opinionated about staying in its lane. These are the four
            rules every manifest is held to.
          </p>
        </header>

        <ol class="rules-grid">
          {designRules.map((rule, index) => (
            <li class="rule-item">
              <span class="rule-number" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              <h3>{rule.title}</h3>
              <p>{rule.body}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="section themes-section">
      <div class="container narrow">
        <header class="section-head">
          <p class="eyebrow">Supported</p>
          <h2>{supportedThemes.length} themes installable today.</h2>
          <p class="section-lede">
            Every theme listed here ships a <code>slatewave.toml</code> manifest
            embedded in the CLI. Click any theme to see its detail page — or
            run <code>slatewave list</code> for the live, machine-readable view.
          </p>
        </header>

        <ul class="themes-grid">
          {supportedThemes.map((theme) => (
            <li>
              <a
                href={`/themes/${theme.data.slug}/`}
                class="theme-pill"
                data-simple-event={`cli_supported_${theme.data.slug.replace(/-/g, '_')}`}
              >
                <span class="theme-pill-name">{theme.data.shortName}</span>
                <span class="theme-pill-cmd">slatewave install {theme.data.cliSlug}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section close">
      <div class="container narrow close-card">
        <h2>Get the CLI.</h2>
        <p class="close-lede">
          Two repos: the Go binary and the Homebrew tap. WTFPL — do whatever you
          want with it.
        </p>
        <div class="close-actions">
          <a
            class="btn btn-primary"
            href="#top"
            data-simple-event="cta_cli_close_install"
          >
            Back to the install command ↑
          </a>
          <a
            class="btn btn-ghost"
            href="https://github.com/kevinlangleyjr/slatewave-cli"
            rel="noopener"
            target="_blank"
            data-simple-event="cta_cli_close_github"
          >
            slatewave-cli ↗
          </a>
          <a
            class="btn btn-ghost"
            href="https://github.com/kevinlangleyjr/homebrew-slatewave"
            rel="noopener"
            target="_blank"
            data-simple-event="cta_cli_close_tap"
          >
            homebrew-slatewave ↗
          </a>
        </div>
      </div>
    </section>
  </article>
</Base>

<script>
  import { trackEvent } from '~/lib/analytics';

  document.querySelectorAll<HTMLButtonElement>('.cli-page [data-copy-command]').forEach((button) => {
    const original = button.textContent ?? 'Copy';
    button.addEventListener('click', async () => {
      const command = button.dataset.copyCommand;
      if (!command) return;
      try {
        await navigator.clipboard.writeText(command);
        button.textContent = 'Copied';
        button.dataset.copied = 'true';
        trackEvent('cli_install_copy_command');
        window.setTimeout(() => {
          button.textContent = original;
          delete button.dataset.copied;
        }, 1800);
      } catch {
        button.textContent = 'Select manually';
        window.setTimeout(() => {
          button.textContent = original;
        }, 1800);
      }
    });
  });
</script>

<style>
  .cli-page {
    --page-accent: #5eead4;
  }

  .hero {
    padding-block: var(--space-16) var(--space-12);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: -20% 30% 0 -10%;
    background: radial-gradient(50% 50% at 50% 50%, color-mix(in oklab, var(--page-accent) 22%, transparent), transparent 70%);
    filter: blur(80px);
    pointer-events: none;
  }

  .hero .container {
    position: relative;
  }

  .eyebrow {
    color: var(--page-accent);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero h1 {
    margin-top: var(--space-3);
    font-size: clamp(2.25rem, 5vw, var(--fs-3xl));
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: var(--lh-tight);
  }

  .tagline {
    margin-top: var(--space-5);
    color: var(--fg-muted);
    font-size: var(--fs-md);
    max-width: 44rem;
  }

  .install-command {
    margin-top: var(--space-8);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: stretch;
    padding: var(--space-4) var(--space-5);
    background: var(--bg-inset);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    gap: var(--space-3);
    max-width: 44rem;
  }

  .install-cmd {
    overflow-x: auto;
    max-width: 100%;
    font-size: var(--fs-sm);
    align-self: center;
    margin: 0;
  }

  .install-cmd code {
    white-space: pre;
    font-family: var(--font-mono);
    color: var(--fg-default);
  }

  .copy-command {
    align-self: center;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-sm);
    background: color-mix(in oklab, var(--page-accent) 18%, transparent);
    color: var(--page-accent);
    border: 1px solid color-mix(in oklab, var(--page-accent) 35%, transparent);
    font-size: var(--fs-xs);
    font-weight: 600;
    cursor: pointer;
    transition: background 120ms ease, color 120ms ease;
  }

  .copy-command:hover,
  .copy-command[data-copied='true'] {
    background: var(--page-accent);
    color: var(--accent-ink);
  }

  @media (max-width: 560px) {
    .install-command {
      grid-template-columns: 1fr;
    }

    .copy-command {
      justify-self: start;
    }
  }

  .hero-actions {
    margin-top: var(--space-6);
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-md);
    font-size: var(--fs-sm);
    font-weight: 600;
    border: 1px solid transparent;
    transition: background 120ms ease, border-color 120ms ease, color 120ms ease, transform 120ms ease;
  }

  .btn-primary {
    background: var(--page-accent);
    color: var(--accent-ink);
  }

  .btn-primary:hover {
    background: color-mix(in oklab, var(--page-accent) 85%, white);
    color: var(--accent-ink);
    transform: translateY(-1px);
  }

  .btn-ghost {
    background: transparent;
    color: var(--fg-default);
    border-color: var(--border-strong);
  }

  .btn-ghost:hover {
    background: var(--bg-raised);
    color: var(--fg-default);
  }

  .btn-link {
    color: var(--fg-muted);
    padding-inline: var(--space-2);
  }

  .btn-link:hover {
    color: var(--page-accent);
  }

  .stats {
    margin-top: var(--space-6);
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
    padding: var(--space-4) var(--space-5);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-size: var(--fs-sm);
    max-width: 44rem;
  }

  .stat {
    display: grid;
    gap: 2px;
  }

  .stat dt {
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    font-weight: 600;
  }

  .stat dd {
    margin: 0;
    color: var(--fg-default);
    font-family: var(--font-mono);
  }

  .stat dd a {
    color: var(--page-accent);
  }

  .stat .muted {
    color: var(--fg-subtle);
    font-family: var(--font-sans);
  }

  .section {
    padding-block: var(--space-12);
  }

  .narrow {
    max-width: 48rem;
  }

  .section-head {
    margin-bottom: var(--space-8);
    max-width: 42rem;
  }

  .section-head h2 {
    margin-top: var(--space-2);
    font-size: clamp(1.75rem, 3vw, var(--fs-xl));
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .section-lede {
    margin-top: var(--space-3);
    color: var(--fg-muted);
  }

  .section-lede code,
  .command-desc code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: var(--fg-default);
    background: var(--bg-inset);
    padding: 1px 6px;
    border-radius: var(--radius-sm);
  }

  .comparison {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  .comparison-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .comparison-label {
    font-size: var(--fs-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    font-weight: 600;
  }

  .comparison-after {
    color: var(--page-accent);
  }

  .snippet {
    margin: 0;
    padding: var(--space-4) var(--space-5);
    background: var(--bg-inset);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--fg-muted);
    overflow-x: auto;
    white-space: pre;
  }

  .snippet-after {
    color: var(--fg-default);
    border-color: color-mix(in oklab, var(--page-accent) 35%, var(--border));
    background: color-mix(in oklab, var(--page-accent) 6%, var(--bg-inset));
  }

  .demo-section :global(.terminal-preview) {
    margin-top: 0;
  }

  .demo-caption {
    margin-top: var(--space-3);
    font-size: var(--fs-xs);
  }

  .demo-caption code {
    font-family: var(--font-mono);
    color: var(--fg-default);
  }

  .commands-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }

  .command-item {
    padding: var(--space-4) var(--space-5);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    display: grid;
    gap: var(--space-2);
  }

  .command-name {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--page-accent);
    font-weight: 600;
  }

  .command-desc {
    margin: 0;
    color: var(--fg-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-snug);
  }

  .rules-grid {
    list-style: none;
    padding: 0;
    counter-reset: rule;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: var(--space-5);
  }

  .rule-item {
    padding: var(--space-5);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    display: grid;
    gap: var(--space-3);
    position: relative;
  }

  .rule-number {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--page-accent);
    font-weight: 600;
    letter-spacing: 0.1em;
  }

  .rule-item h3 {
    font-size: var(--fs-md);
    font-weight: 600;
    color: var(--fg-default);
    margin: 0;
  }

  .rule-item p {
    margin: 0;
    color: var(--fg-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-snug);
  }

  .themes-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: var(--space-3);
  }

  .theme-pill {
    display: grid;
    gap: 2px;
    padding: var(--space-3) var(--space-4);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: inherit;
    text-decoration: none;
    transition: border-color 120ms ease, transform 120ms ease;
  }

  .theme-pill:hover,
  .theme-pill:focus-visible {
    border-color: var(--page-accent);
    transform: translateY(-1px);
  }

  .theme-pill-name {
    font-weight: 600;
    color: var(--fg-default);
    font-size: var(--fs-sm);
  }

  .theme-pill-cmd {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--fg-subtle);
  }

  .theme-pill:hover .theme-pill-cmd {
    color: var(--page-accent);
  }

  .close-card {
    padding: var(--space-8);
    background:
      radial-gradient(circle at 0% 0%, color-mix(in oklab, var(--page-accent) 18%, transparent), transparent 34rem),
      var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
  }

  .close-card h2 {
    font-size: clamp(1.75rem, 3vw, var(--fs-xl));
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .close-lede {
    margin-top: var(--space-3);
    color: var(--fg-muted);
  }

  .close-actions {
    margin-top: var(--space-6);
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .muted {
    color: var(--fg-muted);
    font-size: var(--fs-sm);
  }
</style>
