---
import { getCollection } from 'astro:content';
import Base from '~/layouts/Base.astro';
import ThemeCard from '~/components/theme/ThemeCard.astro';
import PaletteStrip from '~/components/ui/PaletteStrip.astro';
import CodePreview from '~/components/previews/CodePreview.astro';
import OhMyPoshPreview from '~/components/previews/OhMyPoshPreview.astro';
import ObsidianPreview from '~/components/previews/ObsidianPreview.astro';

const themes = (await getCollection('themes'))
  .sort((a, b) => a.data.order - b.data.order);

const shipped = themes.filter((t) => t.data.status !== 'planned');
const shippedCount = shipped.length;

// Pool grouped by category for the "Pick your surface" shuffle. Soft
// category = notes + productivity (the third slot pulls from either).
const editors = shipped.filter((t) => t.data.category === 'editor');
const terminals = shipped.filter((t) => t.data.category === 'terminal');
const softCats = shipped.filter(
  (t) => t.data.category === 'notes' || t.data.category === 'productivity',
);

// SSR defaults (stable across builds, used as no-JS fallback and as the
// first paint before the client shuffle runs).
const defaultEditor = editors[0];
const defaultTerminal = terminals[0];
const defaultSoft = softCats[0];

const heroSample = `// slatewave/palette.ts
export const accent = '#5eead4';

export interface Theme {
  name: string;
  surface: 'editor' | 'terminal' | 'notes';
}

export function apply(theme: Theme): string {
  return \`\${theme.name} on \${theme.surface}\`;
}
`;
---

<Base
  title="Slatewave"
  description="A unified color system for the tools developers use every day — editor, terminal, notes, launcher, and chat, all speaking the same visual language."
  ogImage="/og/home.jpg"
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">A cohesive theme system</p>
        <h1>One palette.<br />Every tool.</h1>
        <p class="lede">
          One palette mapped onto every tool you live in — editor, terminal,
          prompt, notes, launcher, chat. Strings stay teal whichever surface
          you're on. Errors stay rose.
        </p>
        <p class="hero-beta-note">
          <span class="hero-beta-tag">Beta</span>
          All themes and the CLI are in beta — feedback welcome.
          <a href="/changelog/" data-simple-event="cta_home_hero_beta_changelog">See the changelog →</a>
        </p>
        <div class="hero-cta">
          <a class="btn btn-primary" href="/themes/vscode/#install" data-simple-event="cta_home_hero_install">Install VSCode theme</a>
          <a class="btn btn-primary btn-primary-cli" href="/cli/" data-simple-event="cta_home_hero_cli">Install the CLI</a>
          <a class="btn btn-ghost" href="/themes/" data-simple-event="cta_home_hero_browse">Browse {shippedCount} tools</a>
          <a
            class="btn btn-link"
            href="https://github.com/kevinlangleyjr?tab=repositories&q=slatewave"
            rel="noopener"
            target="_blank"
            data-simple-event="cta_home_hero_github"
          >
            View on GitHub
          </a>
        </div>

        <dl class="hero-proof" aria-label="Slatewave proof points">
          <div>
            <dt>{shippedCount}</dt>
            <dd>shipping themes</dd>
          </div>
          <div>
            <dt>1</dt>
            <dd>palette contract</dd>
          </div>
          <div>
            <dt>No</dt>
            <dd>hand-matched ports</dd>
          </div>
        </dl>
      </div>

      <div class="hero-mark" aria-hidden="true">
        <span class="hero-mark-glow hero-mark-glow-teal"></span>
        <span class="hero-mark-glow hero-mark-glow-purple"></span>
        <span class="hero-mark-glow hero-mark-glow-rose"></span>
        <span class="hero-mark-glow hero-mark-glow-amber"></span>
        <img class="hero-mark-icon" src="/brand/icon.svg" alt="" width="908" height="1005" />
      </div>
    </div>
  </section>

  <section class="section positioning">
    <div class="container">
      <div class="positioning-card">
        <p class="eyebrow">Why Slatewave</p>
        <h2>Stop re-picking colors for every tool.</h2>
        <div class="positioning-grid">
          <article>
            <h3>Same colors,<br />every surface.</h3>
            <p>
              Strings stay teal whether you're in VSCode, bat, Helix, or Sublime.
              Errors stay rose. The palette doesn't reset when you switch tools.
            </p>
          </article>
          <article>
            <h3>Mapped,<br />not approximated.</h3>
            <p>
              Each port maps the same semantic roles to its native theme keys —
              <code>terminal.ansi*</code> in VSCode, <code>theme[plus_emph_style]</code>
              in delta. No eyeballing screenshots.
            </p>
          </article>
          <article>
            <h3>Adopt one.<br />Add the rest.</h3>
            <p>
              Install the editor theme today. The terminal, prompt, notes app,
              launcher, and chat ports all use the same hex values when you're
              ready for them.
            </p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="section starter-paths">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Start here</p>
        <h2>Install Slatewave where it will change your day first.</h2>
        <p class="section-lede">
          Pick the workflow you use most, copy the install command, then expand
          the same palette across the rest of your setup.
        </p>
      </header>

      <div class="starter-grid">
        <article class="starter-card" style="--starter-accent: #5eead4;">
          <p class="starter-kicker">Most direct</p>
          <h3>Start in VSCode or Cursor</h3>
          <p>
            Get the editor palette first: syntax, workbench chrome, selections,
            and diff colors all tuned for long sessions.
          </p>
          <a class="starter-link" href="/docs/getting-started/#editor-first-setup" data-simple-event="cta_home_starter_editor">Install editor theme →</a>
        </article>

        <article class="starter-card" style="--starter-accent: #38bdf8;">
          <p class="starter-kicker">Terminal-first</p>
          <h3>Match your prompt and shell</h3>
          <p>
            Carry the same slate foundation and teal accent into Oh My Posh,
            Starship, Ghostty, tmux, and terminal palettes.
          </p>
          <a class="starter-link" href="/docs/getting-started/#terminal-first-setup" data-simple-event="cta_home_starter_terminal">Use terminal bundle →</a>
        </article>

        <article class="starter-card" style="--starter-accent: #5eead4;">
          <p class="starter-kicker">One command</p>
          <h3>Install the whole family at once</h3>
          <p>
            <code>brew install</code> the Slatewave CLI, then <code>slatewave init</code>
            detects what's on your machine and installs every theme you pick — backups,
            uninstall, and all.
          </p>
          <a class="starter-link" href="/cli/" data-simple-event="cta_home_starter_cli">Install the CLI →</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section surfaces">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">The same palette, everywhere</p>
        <h2>A few surfaces. One visual language.</h2>
        <p class="section-lede">
          Editor, terminal, notes — three of the {shippedCount} shipping
          themes, rendered with the authoritative Slatewave palette. These
          previews aren't screenshots; they use the same colors you'd install.
          <a href="/themes/" class="inline-link" data-simple-event="cta_home_surfaces_all">See all {shippedCount} themes →</a>
        </p>
      </header>

      <div class="surface-stack">
        <article class="surface" style="--surface-accent: #5eead4;">
          <header class="surface-head">
            <p class="eyebrow">Editor · VSCode</p>
            <a class="surface-link" href="/themes/vscode/" data-simple-event="cta_home_surface_view_vscode">View theme →</a>
          </header>
          <CodePreview code={heroSample} language="typescript" label="palette.ts" />
        </article>

        <article class="surface" style="--surface-accent: #38bdf8;">
          <header class="surface-head">
            <p class="eyebrow">Terminal · Oh My Posh</p>
            <a class="surface-link" href="/themes/oh-my-posh/" data-simple-event="cta_home_surface_view_oh_my_posh">View theme →</a>
          </header>
          <OhMyPoshPreview />
        </article>

        <article class="surface" style="--surface-accent: #b388ff;">
          <header class="surface-head">
            <p class="eyebrow">Notes · Obsidian</p>
            <a class="surface-link" href="/themes/obsidian/" data-simple-event="cta_home_surface_view_obsidian">View theme →</a>
          </header>
          <ObsidianPreview />
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Themes</p>
        <h2>Pick your surface.</h2>
      </header>
      <ul class="theme-grid" id="surface-grid">
        <li data-category={defaultEditor.data.category}>
          <ThemeCard theme={defaultEditor} />
        </li>
        <li data-category={defaultTerminal.data.category}>
          <ThemeCard theme={defaultTerminal} />
        </li>
        <li data-category={defaultSoft.data.category}>
          <ThemeCard theme={defaultSoft} />
        </li>
      </ul>

      <template id="surface-pool">
        {shipped.map((theme) => (
          <li data-category={theme.data.category}>
            <ThemeCard theme={theme} />
          </li>
        ))}
      </template>
    </div>
  </section>

  <script is:inline>
    (() => {
      const grid = document.getElementById('surface-grid');
      const pool = document.getElementById('surface-pool');
      if (!grid || !(pool instanceof HTMLTemplateElement)) return;
      const items = Array.from(pool.content.querySelectorAll('li[data-category]'));
      const byCat = {};
      for (const el of items) {
        const c = el.dataset.category;
        if (!c) continue;
        (byCat[c] ||= []).push(el);
      }
      const pick = (arr) => arr[Math.floor(Math.random() * arr.length)];
      const editor = byCat.editor && byCat.editor.length ? pick(byCat.editor) : null;
      const terminal = byCat.terminal && byCat.terminal.length ? pick(byCat.terminal) : null;
      const soft = [...(byCat.notes || []), ...(byCat.productivity || [])];
      const third = soft.length ? pick(soft) : null;
      const picks = [editor, terminal, third].filter(Boolean);
      if (picks.length === 3) {
        grid.replaceChildren(...picks.map((el) => el.cloneNode(true)));
      }
    })();
  </script>

  <section class="section">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">The palette</p>
        <h2>A single source of truth.</h2>
        <p class="section-lede">
          Every Slatewave theme is generated from this palette. Change a
          role here, and the same role shifts everywhere else.
        </p>
      </header>
      <PaletteStrip />
    </div>
  </section>

  <section class="section tenets">
    <div class="container">
      <ul class="tenet-grid">
        <li>
          <h3>Coherent</h3>
          <p>Every theme is generated from the same palette, not ported by eye.</p>
        </li>
        <li>
          <h3>Calm</h3>
          <p>Tuned for long sessions: high legibility, low chromatic fatigue.</p>
        </li>
        <li>
          <h3>Open</h3>
          <p>Every theme lives in its own public repo under the WTFPL — do what you want with it.</p>
        </li>
      </ul>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-block: var(--space-20) var(--space-16);
    position: relative;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .hero {
      padding-block: var(--space-12) var(--space-10);
    }
  }

  .hero .container {
    position: relative;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    align-items: center;
    gap: var(--space-12);
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }

  .hero-mark {
    position: relative;
    aspect-ratio: 908 / 1005;
    width: 100%;
    max-width: 360px;
    justify-self: end;
    isolation: isolate;
  }

  @media (max-width: 900px) {
    .hero-mark {
      max-width: 220px;
      justify-self: center;
      margin-top: var(--space-6);
    }
  }

  .hero-mark-icon {
    position: relative;
    width: 100%;
    height: auto;
    z-index: 1;
  }

  .hero-mark-glow {
    position: absolute;
    width: 75%;
    height: 75%;
    border-radius: 50%;
    filter: blur(72px);
    opacity: 0.55;
    z-index: 0;
    pointer-events: none;
  }

  .hero-mark-glow-teal {
    background: var(--sw-teal-300);
    bottom: -8%;
    left: -18%;
  }

  .hero-mark-glow-rose {
    background: var(--sw-rose-400);
    bottom: -10%;
    right: -10%;
    opacity: 0.5;
  }

  .hero-mark-glow-purple {
    background: var(--sw-purple);
    top: -12%;
    left: -8%;
    opacity: 0.45;
  }

  .hero-mark-glow-amber {
    background: var(--sw-amber-400);
    top: -10%;
    right: -16%;
    opacity: 0.4;
  }

  :global([data-theme='light']) .hero-mark-glow {
    opacity: 0.35;
  }

  :global([data-theme='light']) .hero-mark-icon {
    filter: drop-shadow(0 16px 32px rgba(15, 23, 42, 0.12));
  }

  .hero h1 {
    margin-top: var(--space-4);
    font-size: clamp(2.5rem, 6vw, var(--fs-3xl));
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: var(--lh-tight);
  }

  .lede {
    margin-top: var(--space-5);
    max-width: 40rem;
    color: var(--fg-muted);
    font-size: var(--fs-md);
  }

  .hero-beta-note {
    margin-top: var(--space-5);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    color: var(--fg-muted);
    font-size: var(--fs-sm);
  }

  .hero-beta-note a {
    color: var(--accent);
    white-space: nowrap;
  }

  .hero-beta-tag {
    display: inline-flex;
    align-items: center;
    padding: 2px var(--space-2);
    border-radius: 999px;
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--status-warn);
    border: 1px solid color-mix(in oklab, var(--status-warn) 30%, transparent);
    background: color-mix(in oklab, var(--status-warn) 10%, transparent);
  }

  .hero-cta {
    margin-top: var(--space-8);
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .btn-link {
    color: var(--fg-muted);
    padding-inline: var(--space-2);
  }

  .btn-link:hover {
    color: var(--accent);
  }

  .hero-proof {
    margin-top: var(--space-8);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    max-width: 40rem;
  }

  .hero-proof div {
    padding: var(--space-4);
    background: color-mix(in oklab, var(--bg-raised) 78%, transparent);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .hero-proof dt {
    color: var(--fg-default);
    font-size: var(--fs-lg);
    font-weight: 600;
    line-height: var(--lh-tight);
  }

  .hero-proof dd {
    margin-top: var(--space-1);
    color: var(--fg-subtle);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  @media (max-width: 560px) {
    .hero-proof {
      grid-template-columns: 1fr;
    }
  }

  .positioning {
    padding-block: 0 var(--space-16);
  }

  .positioning-card {
    padding: var(--space-8);
    background:
      radial-gradient(circle at 0% 0%, color-mix(in oklab, var(--accent) 16%, transparent), transparent 34rem),
      var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
  }

  .positioning-card h2 {
    margin-top: var(--space-3);
    max-width: 48rem;
    font-size: clamp(1.75rem, 3vw, var(--fs-xl));
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .positioning-grid {
    margin-top: var(--space-8);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .positioning-grid h3 {
    font-size: var(--fs-md);
    font-weight: 600;
  }

  .positioning-grid p {
    margin-top: var(--space-2);
    color: var(--fg-muted);
    font-size: var(--fs-sm);
  }

  @media (max-width: 820px) {
    .positioning-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .positioning-card {
      padding: var(--space-6);
    }
  }

  .starter-paths {
    padding-block: 0 var(--space-16);
  }

  .starter-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .starter-card {
    --starter-accent: var(--accent);
    padding: var(--space-5);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-height: 100%;
  }

  .starter-kicker {
    color: var(--starter-accent);
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .starter-card h3 {
    font-size: var(--fs-md);
    font-weight: 600;
  }

  .starter-card p:not(.starter-kicker) {
    color: var(--fg-muted);
    font-size: var(--fs-sm);
  }

  .starter-link {
    margin-top: auto;
    color: var(--starter-accent);
    font-size: var(--fs-sm);
    font-weight: 600;
  }

  @media (max-width: 860px) {
    .starter-grid {
      grid-template-columns: 1fr;
    }
  }

  .surfaces {
    padding-block: var(--space-16);
    overflow-x: clip;
  }

  .surface-stack {
    display: grid;
    gap: var(--space-10);
  }

  .surface {
    --surface-accent: var(--accent);
    max-width: 52rem;
    margin-inline: auto;
    width: 100%;
    position: relative;
  }

  .surface::before {
    content: '';
    position: absolute;
    inset: -40px -60px;
    background: radial-gradient(50% 50% at 50% 50%, color-mix(in oklab, var(--surface-accent) 14%, transparent), transparent 70%);
    filter: blur(50px);
    z-index: -1;
    pointer-events: none;
  }

  .surface:nth-child(even) {
    margin-left: auto;
    margin-right: 0;
  }

  .surface:nth-child(odd) {
    margin-left: 0;
    margin-right: auto;
  }

  @media (max-width: 720px) {
    .surface {
      margin-inline: 0 !important;
    }
  }

  .surface-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .surface-head .eyebrow {
    color: var(--surface-accent);
  }

  .surface-link {
    font-size: var(--fs-sm);
    color: var(--fg-muted);
  }

  .surface-link:hover {
    color: var(--surface-accent);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-md);
    font-size: var(--fs-sm);
    font-weight: 500;
    border: 1px solid transparent;
    transition: background 120ms ease, border-color 120ms ease, color 120ms ease;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--accent-ink);
  }

  .btn-primary:hover {
    background: color-mix(in oklab, var(--accent) 85%, white);
    color: var(--accent-ink);
  }

  .btn-primary-cli {
    background: color-mix(in oklab, var(--accent) 16%, transparent);
    color: var(--accent);
    border-color: color-mix(in oklab, var(--accent) 35%, transparent);
  }

  .btn-primary-cli:hover {
    background: color-mix(in oklab, var(--accent) 26%, transparent);
    color: var(--accent);
  }

  .btn-ghost {
    background: transparent;
    color: var(--fg-default);
    border-color: var(--border-strong);
  }

  .btn-ghost:hover {
    background: var(--bg-raised);
    color: var(--fg-default);
  }

  .section {
    padding-block: var(--space-16);
  }

  .section-head {
    margin-bottom: var(--space-8);
    max-width: 40rem;
  }

  .section-head h2 {
    margin-top: var(--space-2);
    font-size: clamp(1.75rem, 3vw, var(--fs-xl));
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .section-lede {
    margin-top: var(--space-3);
    color: var(--fg-muted);
  }

  .inline-link {
    color: var(--accent);
    white-space: nowrap;
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-5);
    list-style: none;
    padding: 0;
  }

  .tenet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-6);
    list-style: none;
    padding: 0;
  }

  .tenet-grid li h3 {
    font-size: var(--fs-md);
    font-weight: 600;
    color: var(--fg-default);
  }

  .tenet-grid li p {
    margin-top: var(--space-2);
    color: var(--fg-muted);
    font-size: var(--fs-sm);
  }
</style>
