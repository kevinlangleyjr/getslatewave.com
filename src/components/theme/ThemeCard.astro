---
import type { CollectionEntry } from 'astro:content';
import Badge from '~/components/ui/Badge.astro';
import { fetchRepoMeta } from '~/lib/github';
import { relativeTime, formatStars } from '~/lib/format';

interface Props {
  theme: CollectionEntry<'themes'>;
}

const { theme } = Astro.props;
const { data } = theme;

const categoryLabel: Record<typeof data.category, string> = {
  editor: 'Editor',
  terminal: 'Terminal',
  notes: 'Notes',
  browser: 'Browser',
  chat: 'Chat',
  productivity: 'Productivity',
  other: 'Other',
};

const accentStyle = data.accent ? `--card-accent: ${data.accent}` : undefined;
const isPlanned = data.status === 'planned';
const href = isPlanned ? data.repo.url : `/themes/${data.slug}/`;

const meta = isPlanned ? null : await fetchRepoMeta(data.repo.owner, data.repo.name);
const version = meta?.latestRelease?.tag ?? null;
const pushedRel = meta?.pushedAt ? relativeTime(meta.pushedAt) : null;
---

<a
  class:list={['card', { 'card-planned': isPlanned }]}
  href={href}
  style={accentStyle}
  data-category={data.category}
  data-status={data.status}
  target={isPlanned ? '_blank' : undefined}
  rel={isPlanned ? 'noopener' : undefined}
>
  <header class="card-head">
    <span class="category">{categoryLabel[data.category]}</span>
    <Badge tone={data.status}>{data.status}</Badge>
  </header>

  <div class="card-body">
    <h3>{data.shortName}</h3>
    <p class="tagline">{data.tagline}</p>
  </div>

  <footer class="card-foot">
    {meta && (meta.stars > 0 || version || pushedRel) && (
      <dl class="stats" aria-label="Repository stats">
        {meta.stars > 0 && (
          <div class="stat">
            <dt aria-label="Stars">★</dt>
            <dd>{formatStars(meta.stars)}</dd>
          </div>
        )}
        {version && (
          <div class="stat">
            <dt>Version</dt>
            <dd class="mono">{version}</dd>
          </div>
        )}
        {pushedRel && (
          <div class="stat">
            <dt>Updated</dt>
            <dd>{pushedRel}</dd>
          </div>
        )}
      </dl>
    )}
    <span class="cta">
      {isPlanned ? 'Learn more' : 'Explore theme'}
      <span aria-hidden="true">{isPlanned ? '↗' : '→'}</span>
    </span>
  </footer>
</a>

<style>
  .card {
    --card-accent: var(--accent);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-height: 220px;
    padding: var(--space-5);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    color: var(--fg-default);
    transition: border-color 160ms ease, transform 160ms ease, background 160ms ease;
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 100% at 0% 0%, color-mix(in oklab, var(--card-accent) 18%, transparent), transparent 60%);
    opacity: 0.6;
    pointer-events: none;
    transition: opacity 160ms ease;
  }

  .card:hover {
    border-color: color-mix(in oklab, var(--card-accent) 40%, var(--border));
    transform: translateY(-2px);
    color: var(--fg-default);
  }

  .card:hover::before {
    opacity: 1;
  }

  .card-planned {
    opacity: 0.7;
  }

  .card-planned:hover {
    opacity: 1;
  }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .category {
    font-size: var(--fs-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    font-weight: 600;
  }

  .card-body h3 {
    font-size: var(--fs-lg);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .tagline {
    margin-top: var(--space-2);
    color: var(--fg-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-snug);
  }

  .card-foot {
    margin-top: auto;
    display: grid;
    gap: var(--space-3);
  }

  .stats {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin: 0;
    padding-top: var(--space-3);
    border-top: 1px solid var(--border);
    font-size: var(--fs-xs);
  }

  .stat {
    display: inline-flex;
    gap: 4px;
    align-items: baseline;
    color: var(--fg-subtle);
  }

  .stat dt {
    font-weight: 500;
  }

  .stat dd {
    color: var(--fg-muted);
    margin: 0;
  }

  .stat .mono {
    font-family: var(--font-mono);
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--fs-sm);
    color: var(--card-accent);
    font-weight: 500;
  }
</style>
