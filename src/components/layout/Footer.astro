---
import { getCollection } from 'astro:content';

const year = new Date().getFullYear();

const themes = (await getCollection('themes', ({ data }) => data.status !== 'planned'))
  .sort((a, b) => a.data.order - b.data.order);
---

<footer class="site-footer">
  <div class="container">
    <div class="grid">
      <div class="brand-col">
        <a class="brand" href="/" aria-label="Slatewave home">
          <img
            class="footer-wordmark footer-wordmark-dark"
            src="/brand/wordmark.png"
            alt="Slatewave"
            width="1000"
            height="154"
          />
          <img
            class="footer-wordmark footer-wordmark-light"
            src="/brand/wordmark-light.png"
            alt=""
            width="1000"
            height="154"
          />
        </a>
        <p class="muted">One palette. Every tool.</p>
      </div>

      <div>
        <p class="eyebrow">Explore</p>
        <ul>
          <li><a href="/themes/">All themes</a></li>
          <li><a href="/playground/">Playground</a></li>
          <li><a href="/colors/">Colors</a></li>
          <li><a href="/docs/">Docs</a></li>
          <li><a href="/changelog/">Changelog</a></li>
        </ul>
      </div>

      <div class="themes-col">
        <p class="eyebrow">Themes</p>
        <ul class="themes-list">
          {themes.map((theme) => (
            <li><a href={`/themes/${theme.data.slug}/`}>{theme.data.shortName}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <p class="small muted">
      Designed and built by <a href="https://kevinlangleyjr.dev" rel="noopener" target="_blank">Kevin Langley Jr.</a>
      &middot; &copy; {year} Slatewave &middot; Open source under the <a href="http://www.wtfpl.net/" rel="noopener" target="_blank">WTFPL</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-24);
    padding-block: var(--space-12);
    border-top: 1px solid var(--border);
    font-size: var(--fs-sm);
  }

  .grid {
    display: grid;
    grid-template-columns: 2fr 1fr 2fr;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  ul {
    list-style: none;
    padding: 0;
    margin-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .themes-list {
    display: block;
    columns: 2 8rem;
    column-gap: var(--space-6);
  }

  .themes-list li {
    break-inside: avoid;
    margin-top: var(--space-1);
  }

  .themes-list li:first-child {
    margin-top: 0;
  }

  @media (min-width: 1024px) {
    .themes-list {
      columns: 3 8rem;
    }
  }

  .brand {
    display: inline-block;
    margin-bottom: var(--space-3);
  }

  .footer-wordmark {
    height: 36px;
    width: auto;
    max-width: 100%;
    display: none;
  }

  :global([data-theme='light']) .footer-wordmark-dark,
  :global([data-theme='dark']) .footer-wordmark-light {
    display: block;
  }

  .muted {
    color: var(--fg-subtle);
  }

  .small {
    font-size: var(--fs-xs);
  }
</style>
