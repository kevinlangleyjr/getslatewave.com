---
import { getCollection } from 'astro:content';

const year = new Date().getFullYear();

const themes = (await getCollection('themes', ({ data }) => data.status !== 'planned'))
  .sort((a, b) => a.data.order - b.data.order);
---

<footer class="site-footer">
  <div class="container">
    <div class="grid">
      <div>
        <p class="brand">Slatewave</p>
        <p class="muted">One palette. Every tool.</p>
      </div>

      <div>
        <p class="eyebrow">Explore</p>
        <ul>
          <li><a href="/themes/">All themes</a></li>
          <li><a href="/colors/">Colors</a></li>
          <li><a href="/docs/">Docs</a></li>
          <li><a href="/changelog/">Changelog</a></li>
        </ul>
      </div>

      <div>
        <p class="eyebrow">Themes</p>
        <ul>
          {themes.map((theme) => (
            <li><a href={`/themes/${theme.data.slug}/`}>{theme.data.shortName}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <p class="small muted">&copy; {year} Slatewave. Open source under the <a href="http://www.wtfpl.net/" rel="noopener" target="_blank">WTFPL</a>.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-24);
    padding-block: var(--space-12);
    border-top: 1px solid var(--border);
    font-size: var(--fs-sm);
  }

  .grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  ul {
    list-style: none;
    padding: 0;
    margin-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .brand {
    font-weight: 600;
    color: var(--fg-default);
  }

  .muted {
    color: var(--fg-subtle);
  }

  .small {
    font-size: var(--fs-xs);
  }
</style>
