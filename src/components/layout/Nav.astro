---
import ThemeToggle from '~/components/ui/ThemeToggle.astro';

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/docs/') {
    return pathname.startsWith('/docs/');
  }

  return pathname === href || pathname.startsWith(href);
};

const links = [
  { href: '/cli/', label: 'Install' },
  { href: '/themes/', label: 'Themes' },
  { href: '/playground/', label: 'Playground' },
  { href: '/colors/', label: 'Colors' },
  { href: '/docs/', label: 'Docs' },
  { href: '/changelog/', label: 'Changelog' },
];
---

<header class="site-nav" data-nav-open="false">
  <div class="container nav-inner">
    <a class="brand" href="/" aria-label="Slatewave home">
      <img class="brand-mark" src="/brand/icon.svg" alt="" width="51" height="56" />
      <img
        class="brand-wordmark brand-wordmark-dark"
        src="/brand/wordmark.png"
        alt="Slatewave"
        width="1000"
        height="154"
      />
      <img
        class="brand-wordmark brand-wordmark-light"
        src="/brand/wordmark-light.png"
        alt=""
        width="1000"
        height="154"
      />
    </a>

    <div class="nav-actions">
      <nav aria-label="Primary" class="nav-menu" id="primary-nav">
        <ul>
          {links.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={['nav-link', { active: isActive(href) }]}
                data-simple-event={`nav_header_${label.toLowerCase()}`}
              >
                {label}
              </a>
            </li>
          ))}
          <li>
            <a
              class="nav-link"
              href="https://github.com/kevinlangleyjr?tab=repositories&q=slatewave"
              rel="me noopener"
              target="_blank"
              data-simple-event="nav_header_github"
            >
              GitHub
            </a>
          </li>
        </ul>
      </nav>

      <ThemeToggle />

      <button
        type="button"
        class="nav-toggle"
        aria-label="Toggle navigation"
        aria-controls="primary-nav"
        aria-expanded="false"
        data-nav-toggle
      >
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line class="nav-toggle-line nav-toggle-line-top" x1="4" y1="7" x2="20" y2="7"/>
          <line class="nav-toggle-line nav-toggle-line-mid" x1="4" y1="12" x2="20" y2="12"/>
          <line class="nav-toggle-line nav-toggle-line-bot" x1="4" y1="17" x2="20" y2="17"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector('.site-nav');
    const toggle = document.querySelector('[data-nav-toggle]');
    if (!header || !toggle) return;

    const setOpen = (open) => {
      header.dataset.navOpen = open ? 'true' : 'false';
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    };

    toggle.addEventListener('click', () => {
      setOpen(header.dataset.navOpen !== 'true');
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && header.dataset.navOpen === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });

    document.addEventListener('click', (e) => {
      if (header.dataset.navOpen !== 'true') return;
      if (!header.contains(e.target)) setOpen(false);
    });

    header.querySelectorAll('.nav-link').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });
  })();
</script>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(160%) blur(12px);
    background: color-mix(in oklab, var(--bg-base) 80%, transparent);
    border-bottom: 1px solid var(--border);
  }

  :global([data-theme='dark']) .site-nav {
    background: color-mix(
      in oklab,
      color-mix(in oklab, var(--bg-base), white 8%) 85%,
      transparent
    );
  }

  :global([data-theme='light']) .site-nav {
    background: color-mix(in oklab, var(--bg-raised) 85%, transparent);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    min-height: 64px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .brand:hover {
    color: var(--fg-default);
  }

  .brand-mark {
    height: 28px;
    width: auto;
    display: block;
  }

  .brand-wordmark {
    height: 22px;
    width: auto;
    display: none;
  }

  :global([data-theme='light']) .brand-wordmark-dark,
  :global([data-theme='dark']) .brand-wordmark-light {
    display: block;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  nav ul {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    padding: 0;
  }

  .nav-link {
    display: inline-block;
    padding: var(--space-2) var(--space-3);
    color: var(--fg-muted);
    font-size: var(--fs-sm);
    border-radius: var(--radius-md);
  }

  .nav-link:hover {
    color: var(--fg-default);
    background: var(--bg-raised);
  }

  .nav-link.active {
    color: var(--fg-default);
    background: var(--accent-soft);
  }

  .nav-toggle {
    display: none;
    appearance: none;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--fg-default);
    width: 36px;
    height: 36px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
  }

  .nav-toggle:hover {
    background: var(--bg-raised);
    color: var(--fg-default);
  }

  .nav-toggle:focus-visible {
    outline-offset: 0;
    outline-color: var(--border-strong);
  }

  .site-nav[data-nav-open='true'] .nav-toggle {
    background: var(--accent-soft);
    color: var(--fg-default);
    border-color: color-mix(in oklab, var(--accent) 35%, var(--border));
  }

  .nav-toggle-line {
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .nav-toggle-line-top { transform-origin: 12px 7px; }
  .nav-toggle-line-mid { transform-origin: 12px 12px; }
  .nav-toggle-line-bot { transform-origin: 12px 17px; }

  .site-nav[data-nav-open='true'] .nav-toggle-line-top {
    transform: translateY(5px) rotate(45deg);
  }

  .site-nav[data-nav-open='true'] .nav-toggle-line-mid {
    opacity: 0;
  }

  .site-nav[data-nav-open='true'] .nav-toggle-line-bot {
    transform: translateY(-5px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: inline-flex;
    }

    .nav-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg-base);
      border-bottom: 1px solid var(--border);
      padding: var(--space-3) var(--space-4);
      visibility: hidden;
      opacity: 0;
      transform: translateY(-6px);
      transition: opacity 160ms ease, transform 160ms ease, visibility 160ms;
    }

    :global([data-theme='dark']) .nav-menu {
      background: color-mix(in oklab, var(--bg-base), white 8%);
    }

    :global([data-theme='light']) .nav-menu {
      background: var(--bg-raised);
    }

    .site-nav[data-nav-open='true'] .nav-menu {
      visibility: visible;
      opacity: 1;
      transform: translateY(0);
    }

    .nav-menu ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .nav-menu .nav-link {
      display: block;
      padding: var(--space-3) var(--space-3);
      font-size: var(--fs-md);
      border-radius: var(--radius-md);
    }
  }

  @media (max-width: 480px) {
    .brand-mark {
      height: 24px;
      width: auto;
    }

    .brand-wordmark {
      height: 18px;
    }

    .nav-inner {
      gap: var(--space-3);
    }
  }
</style>
