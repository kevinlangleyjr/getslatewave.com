---
import ThemeToggle from '~/components/ui/ThemeToggle.astro';

const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/') || pathname.startsWith(href);

const links = [
  { href: '/themes/', label: 'Themes' },
  { href: '/playground/', label: 'Playground' },
  { href: '/colors/', label: 'Colors' },
  { href: '/docs/', label: 'Docs' },
  { href: '/changelog/', label: 'Changelog' },
];
---

<header class="site-nav">
  <div class="container nav-inner">
    <a class="brand" href="/" aria-label="Slatewave home">
      <img class="brand-mark" src="/brand/icon.png" alt="" width="56" height="56" />
      <img
        class="brand-wordmark brand-wordmark-dark"
        src="/brand/wordmark.png"
        alt="Slatewave"
        width="1000"
        height="154"
      />
      <img
        class="brand-wordmark brand-wordmark-light"
        src="/brand/wordmark-light.png"
        alt=""
        width="1000"
        height="154"
      />
    </a>

    <nav aria-label="Primary">
      <ul>
        {links.map(({ href, label }) => (
          <li>
            <a href={href} class:list={['nav-link', { active: isActive(href) }]}>{label}</a>
          </li>
        ))}
        <li>
          <a
            class="nav-link"
            href="https://github.com/kevinlangleyjr?tab=repositories&q=slatewave"
            rel="me noopener"
            target="_blank"
          >
            GitHub
          </a>
        </li>
      </ul>
    </nav>

    <ThemeToggle />
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(160%) blur(12px);
    background: color-mix(in oklab, var(--bg-base) 80%, transparent);
    border-bottom: 1px solid var(--border);
  }

  :global([data-theme='dark']) .site-nav {
    background: color-mix(
      in oklab,
      color-mix(in oklab, var(--bg-base), white 8%) 85%,
      transparent
    );
  }

  :global([data-theme='light']) .site-nav {
    background: color-mix(in oklab, var(--bg-raised) 85%, transparent);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    min-height: 64px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .brand:hover {
    color: var(--fg-default);
  }

  .brand-mark {
    width: 28px;
    height: 28px;
    display: block;
  }

  .brand-wordmark {
    height: 22px;
    width: auto;
    display: none;
  }

  :global([data-theme='light']) .brand-wordmark-dark,
  :global([data-theme='dark']) .brand-wordmark-light {
    display: block;
  }

  nav ul {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    padding: 0;
  }

  .nav-link {
    display: inline-block;
    padding: var(--space-2) var(--space-3);
    color: var(--fg-muted);
    font-size: var(--fs-sm);
    border-radius: var(--radius-md);
  }

  .nav-link:hover {
    color: var(--fg-default);
    background: var(--bg-raised);
  }

  .nav-link.active {
    color: var(--fg-default);
    background: var(--accent-soft);
  }

  @media (max-width: 640px) {
    .nav-link {
      padding: var(--space-2);
    }
    :global([data-theme='light']) .brand-wordmark-dark,
    :global([data-theme='dark']) .brand-wordmark-light {
      display: none;
    }
  }
</style>
