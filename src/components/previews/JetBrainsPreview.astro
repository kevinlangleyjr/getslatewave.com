---
/**
 * Pure HTML/CSS rendering of GoLand (JetBrains IDE family) with Slatewave
 * applied. The editor content is rendered through Shiki using the real
 * Slatewave theme; everything around it — the project/branch chips, the
 * dual icon rails, the breadcrumb in the status bar, the Trial pill — is
 * hand-built chrome scoped to the JetBrains slatewave.theme.json tokens
 * (surface = #282c34, chrome = #21252b, slate-700 selection bg, teal-300
 * selection fg).
 */

import { getHighlighter, slatewaveThemeName } from '~/lib/shiki';

const sample = `/**
 * Build-time GitHub metadata fetchers.
 *
 * Public-repo data only. Unauthenticated requests are rate-limited to
 * 60/hour per IP; set GITHUB_TOKEN in .env (or the CI environment) to
 * raise that to 5000/hour.
 *
 * Results are cached to \`node_modules/.cache/slatewave-github/\` with a
 * 30-minute TTL so dev hot-reloads don't burn API quota.
 */
import { mkdir, readFile, writeFile } from 'node:fs/promises';
import { join } from 'node:path';

const CACHE_DIR = join(process.cwd(), 'node_modules', '.cache', 'slatewave-github');
const TTL_MS = 30 * 60 * 1000;

export interface RepoMeta {
  stars: number;
  pushedAt: string;
  defaultBranch: string;
  openIssues: number;
  latestRelease: Release | null;
}

export interface Release {
  tag: string;
  name: string;
  publishedAt: string;
  url: string;
  body: string;
  isPrerelease: boolean;
}

const memory = new Map<string, Promise<unknown>>();

function cacheKey(parts: string[]): string {
  return parts.join('__').replace(/[^a-zA-Z0-9_]/g, '_');
}

async function readCache<T>(key: string): Promise<T | null> {
  try {
    const raw = await readFile(join(CACHE_DIR, \`\${key}.json\`), 'utf8');
    const parsed = JSON.parse(raw) as { data: T; at: number };
    if (Date.now() - parsed.at < TTL_MS) return parsed.data;
  } catch {
    /* no cache yet */
  }
  return null;
}`;

const highlighter = await getHighlighter();
const html = highlighter.codeToHtml(sample, {
  lang: 'typescript',
  theme: slatewaveThemeName,
});

const lineCount = sample.split('\n').length;

interface Node {
  type: 'folder' | 'file' | 'root' | 'libroot' | 'special';
  name: string;
  ext?: 'ts' | 'json' | 'md' | 'env' | 'js' | 'gradle';
  open?: boolean;
  active?: boolean;
  selected?: boolean;
  vcs?: 'modified' | 'added' | 'ignored';
  annotation?: string;
  indent: number;
}

const tree: Node[] = [
  { type: 'root', name: 'getslatewave', annotation: '~/Development/Personal/slatewave/getslatewave', indent: 0, open: true },
  { type: 'folder', name: '.astro', indent: 1 },
  { type: 'folder', name: '.github', indent: 1 },
  { type: 'folder', name: '.vscode', indent: 1 },
  { type: 'folder', name: 'dist', indent: 1, vcs: 'ignored' },
  { type: 'folder', name: 'docs', indent: 1 },
  { type: 'libroot', name: 'node_modules', annotation: 'library root', indent: 1 },
  { type: 'folder', name: 'public', indent: 1 },
  { type: 'folder', name: 'src', indent: 1, open: true },
  { type: 'folder', name: 'components', indent: 2 },
  { type: 'folder', name: 'content', indent: 2 },
  { type: 'folder', name: 'layouts', indent: 2 },
  { type: 'folder', name: 'lib', indent: 2, open: true },
  { type: 'folder', name: 'fonts', indent: 3 },
  { type: 'file', name: 'analytics.ts', ext: 'ts', indent: 3 },
  { type: 'file', name: 'format.ts', ext: 'ts', indent: 3 },
  { type: 'file', name: 'github.ts', ext: 'ts', indent: 3, active: true },
  { type: 'file', name: 'shiki.ts', ext: 'ts', indent: 3 },
  { type: 'folder', name: 'pages', indent: 2 },
  { type: 'folder', name: 'styles', indent: 2 },
  { type: 'file', name: 'content.config.ts', ext: 'ts', indent: 2 },
  { type: 'file', name: '.env', ext: 'env', indent: 1, vcs: 'ignored' },
  { type: 'file', name: '.env.example', ext: 'env', indent: 1 },
  { type: 'file', name: '.gitignore', ext: 'env', indent: 1 },
  { type: 'file', name: 'astro.config.mjs', ext: 'js', indent: 1 },
  { type: 'file', name: 'package.json', ext: 'json', indent: 1 },
  { type: 'file', name: 'pnpm-lock.yaml', ext: 'json', indent: 1, selected: true },
  { type: 'file', name: 'README.md', ext: 'md', indent: 1 },
  { type: 'file', name: 'tsconfig.json', ext: 'json', indent: 1 },
  { type: 'special', name: 'External Libraries', indent: 0 },
  { type: 'special', name: 'Scratches and Consoles', indent: 0 },
];

interface Tab {
  name: string;
  ext: 'ts' | 'md';
  active?: boolean;
}

const tabs: Tab[] = [
  { name: 'README.md', ext: 'md' },
  { name: 'github.ts', ext: 'ts', active: true },
];

const breadcrumbs = ['getslatewave', 'src', 'lib', 'github.ts', 'RepoMeta'];

type VcsMark = 'added' | 'modified' | null;
const vcsMarkers: VcsMark[] = Array.from({ length: lineCount }, (_, i) => {
  if (i >= 18 && i <= 22) return 'added';
  if (i === 13 || (i >= 25 && i <= 28)) return 'modified';
  return null;
});

const minimapStyles = Array.from({ length: lineCount }, (_, i) => {
  const w = 30 + ((i * 13) % 60);
  const intensity = (i * 7) % 100;
  return `width:${w}%;opacity:${0.2 + intensity / 240}`;
});

interface BreadcrumbEntry {
  label: string;
  iconKind: 'proj' | 'folder' | 'ts' | 'iface';
}

const breadcrumbEntries: BreadcrumbEntry[] = breadcrumbs.map((label, i) => {
  if (i === 0) return { label, iconKind: 'proj' };
  if (i === breadcrumbs.length - 1) return { label, iconKind: 'iface' };
  if (i === breadcrumbs.length - 2) return { label, iconKind: 'ts' };
  return { label, iconKind: 'folder' };
});
---

<figure class="jb-preview" aria-label="Slatewave applied to GoLand">
  <div class="window">
    <header class="title-bar" aria-hidden="true">
      <div class="dots">
        <span class="dot dot-r"></span>
        <span class="dot dot-y"></span>
        <span class="dot dot-g"></span>
      </div>
      <div class="proj-chip">
        <span class="proj-icon">G</span>
        <span class="proj-name">getslatewave</span>
        <span class="caret">▾</span>
      </div>
      <div class="branch-chip">
        <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="6" cy="6" r="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="12" r="2"/>
          <path d="M6 8v8"/><path d="M8 6h6a4 4 0 0 1 4 4v0"/>
        </svg>
        <span>main</span>
        <span class="caret">▾</span>
      </div>

      <div class="title-spacer"></div>

      <div class="run-controls">
        <span class="run-config">
          <span>Add Configuration</span>
          <span class="caret">▾</span>
        </span>
        <span class="run-btn">
          <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"/></svg>
        </span>
        <span class="run-btn">
          <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="6"/><path d="M2 12h2M20 12h2M12 2v2M12 20v2"/></svg>
        </span>
        <span class="run-btn">⋯</span>
      </div>

      <div class="title-tools">
        <span class="ti">✦</span>
        <span class="ti">⌕</span>
        <span class="ti">⚙</span>
      </div>
    </header>

    <div class="workbench">
      <aside class="rail rail-left" aria-hidden="true">
        <div class="rail-icon active">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          </svg>
        </div>
        <div class="rail-icon">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6">
            <circle cx="6" cy="6" r="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="12" r="2"/>
            <path d="M6 8v8"/><path d="M8 6h6a4 4 0 0 1 4 4v0"/>
          </svg>
        </div>
        <div class="rail-icon">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="3" y="3" width="18" height="14" rx="2"/>
            <path d="M8 21h8M12 17v4"/>
          </svg>
        </div>
        <div class="rail-icon">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6">
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </div>
        <div class="rail-icon bottom">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6">
            <polyline points="4 17 10 11 4 5"/>
            <line x1="12" y1="19" x2="20" y2="19"/>
          </svg>
        </div>
        <div class="rail-icon">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6">
            <circle cx="12" cy="12" r="9"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
          </svg>
        </div>
        <div class="rail-icon">⋯</div>
      </aside>

      <aside class="sidebar">
        <div class="sidebar-head">
          <span>Project</span>
          <span class="caret">▾</span>
          <span class="sidebar-actions">⋯</span>
        </div>
        <div class="tree">
          {tree.map((n) => (
            <div class:list={['node', `type-${n.type}`, { active: n.active, selected: n.selected, vcs: n.vcs }]}>
              <span class="indent" style={`width:${n.indent * 12}px`}></span>
              {(n.type === 'folder' || n.type === 'libroot' || n.type === 'root' || n.type === 'special') ? (
                <span class="caret-cell">{
                  n.type === 'special' ? '▸' : (n.open ? '▾' : '▸')
                }</span>
              ) : (
                <span class="caret-cell"></span>
              )}
              {n.type === 'root' && (
                <span class="ficon proj">G</span>
              )}
              {n.type === 'folder' && (
                <svg class="ficon folder" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                </svg>
              )}
              {n.type === 'libroot' && (
                <svg class="ficon folder libroot" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                  <circle cx="18" cy="6" r="2.5" fill="#fbbf24" stroke="none"/>
                </svg>
              )}
              {n.type === 'special' && (
                <svg class="ficon folder" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path d="M3 5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                  <line x1="8" y1="9" x2="16" y2="9"/>
                  <line x1="8" y1="13" x2="16" y2="13"/>
                </svg>
              )}
              {n.type === 'file' && (
                <span class={`ficon file-ext ext-${n.ext}`}>{
                  n.ext === 'ts' ? 'TS' :
                  n.ext === 'json' ? '{}' :
                  n.ext === 'md' ? 'M' :
                  n.ext === 'js' ? 'JS' :
                  n.ext === 'env' ? '.E' : '·'
                }</span>
              )}
              <span class="node-name">{n.name}</span>
              {n.annotation && <span class="node-annotation">{n.annotation}</span>}
            </div>
          ))}
        </div>
      </aside>

      <section class="editor-pane">
        <div class="tab-bar">
          {tabs.map((t) => (
            <div class:list={['tab', { active: t.active }]}>
              <span class={`ficon file-ext ext-${t.ext}`}>{t.ext === 'ts' ? 'TS' : 'M'}</span>
              <span class="tab-name">{t.name}</span>
              <span class="tab-close">×</span>
            </div>
          ))}
          <div class="tab-actions" aria-hidden="true">
            <span class="diag diag-error">6</span>
            <span class="diag diag-warn">4</span>
            <span class="diag diag-ok">2</span>
            <span class="ti">⌃</span>
            <span class="ti">⌄</span>
          </div>
        </div>

        <div class="editor">
          <div class="vcs-gutter" aria-hidden="true">
            {vcsMarkers.map((m) => (
              <div class:list={['vcs-marker', m]}></div>
            ))}
          </div>
          <div class="gutter" aria-hidden="true">
            {Array.from({ length: lineCount }, (_, i) => (
              <div class="ln">{i + 1}</div>
            ))}
          </div>
          <div class="code" set:html={html} />
          <div class="minimap" aria-hidden="true">
            {minimapStyles.map((s) => (
              <div class="mini-ln" style={s}></div>
            ))}
          </div>
        </div>
      </section>

      <aside class="rail rail-right" aria-hidden="true">
        <div class="rail-icon">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6">
            <ellipse cx="12" cy="5" rx="9" ry="3"/>
            <path d="M3 5v6c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/>
            <path d="M3 11v6c0 1.66 4.03 3 9 3s9-1.34 9-3v-6"/>
          </svg>
        </div>
        <div class="rail-icon">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z"/>
          </svg>
        </div>
        <div class="rail-icon">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <path d="M9 9h6v6H9z"/>
          </svg>
        </div>
      </aside>
    </div>

    <footer class="status-bar" aria-hidden="true">
      <div class="status-left">
        {breadcrumbEntries.map((entry, i) => (
          <Fragment>
            {i > 0 && <span class="bc-sep">›</span>}
            <span class="bc-icon">
              {entry.iconKind === 'proj' && <span class="bc-mini-icon proj">G</span>}
              {entry.iconKind === 'folder' && (
                <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
              )}
              {entry.iconKind === 'ts' && <span class="bc-mini-icon ts">TS</span>}
              {entry.iconKind === 'iface' && <span class="bc-mini-icon iface">I</span>}
            </span>
            <span class="bc-part">{entry.label}</span>
          </Fragment>
        ))}
      </div>
      <div class="status-right">
        <span class="status-cell muted">20:20</span>
        <span class="status-cell">
          <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="6" cy="6" r="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="12" r="2"/>
            <path d="M6 8v8"/><path d="M8 6h6a4 4 0 0 1 4 4v0"/>
          </svg>
        </span>
        <span class="status-cell muted">LF</span>
        <span class="status-cell muted">UTF-8</span>
        <span class="status-cell muted">2 spaces</span>
        <span class="status-cell muted">
          <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="9" rx="1"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
        </span>
        <span class="trial-pill">Trial</span>
      </div>
    </footer>
  </div>
</figure>

<style>
  .jb-preview {
    margin: 0;
    padding: var(--space-8) var(--space-6);
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(15, 23, 42, 0.85), transparent 60%),
      var(--bg-default);
    border-radius: var(--radius-lg);
  }

  .window {
    background: #282c34;
    border: 1px solid #0f172a;
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 25px 60px -15px rgba(0, 0, 0, 0.6);
    font-family: var(--font-sans);
    color: #e2e8f0;
    display: flex;
    flex-direction: column;
    min-height: 580px;
  }

  /* Title bar */
  .title-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: #21252b;
    border-bottom: 1px solid #1a1f28;
    font-size: 11.5px;
    color: #cbd5e1;
  }

  .dots { display: inline-flex; gap: 8px; margin-right: 6px; }
  .dot { width: 12px; height: 12px; border-radius: 50%; }
  .dot-r { background: #fb7185; }
  .dot-y { background: #fbbf24; }
  .dot-g { background: #5eead4; }

  .proj-chip,
  .branch-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 8px;
    border-radius: 5px;
    background: transparent;
    color: #cbd5e1;
    line-height: 1;
  }

  .proj-chip:hover, .branch-chip:hover { background: rgba(94, 234, 212, 0.08); }

  .proj-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border-radius: 4px;
    background: linear-gradient(135deg, #5eead4, #38bdf8);
    color: #0f172a;
    font-size: 9px;
    font-weight: 800;
  }

  .proj-name { font-weight: 500; }

  .branch-chip svg { color: #94a3b8; }

  .caret { color: #475569; font-size: 9px; }

  .title-spacer { flex: 1; }

  .run-controls {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 4px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.03);
  }

  .run-config {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 10px;
    color: #94a3b8;
    font-size: 11px;
  }

  .run-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 4px;
    color: #94a3b8;
    font-size: 12px;
  }

  .run-btn svg { color: #5eead4; }
  .run-btn:nth-child(3) svg { color: #fb7185; }

  .title-tools {
    display: inline-flex;
    gap: 8px;
    margin-left: 8px;
    color: #475569;
    font-size: 13px;
  }

  /* Workbench: rail-left | sidebar | editor | rail-right */
  .workbench {
    display: grid;
    grid-template-columns: 32px 240px minmax(0, 1fr) 32px;
    flex: 1;
    min-height: 0;
  }

  /* Narrow icon rails */
  .rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 4px 0;
    background: #21252b;
    color: #64748b;
  }

  .rail-left { border-right: 1px solid #1a1f28; }
  .rail-right { border-left: 1px solid #1a1f28; }

  .rail-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    margin: 1px 0;
    color: #64748b;
    font-size: 11px;
  }

  .rail-icon.active {
    color: #5eead4;
    background: rgba(94, 234, 212, 0.10);
  }

  .rail-icon.bottom { margin-top: auto; }

  /* Sidebar */
  .sidebar {
    background: #21252b;
    border-right: 1px solid #1a1f28;
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
  }

  .sidebar-head {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 8px 12px 6px;
    font-size: 12px;
    color: #cbd5e1;
    font-weight: 500;
  }

  .sidebar-head .sidebar-actions {
    margin-left: auto;
    color: #475569;
  }

  .tree {
    overflow-y: auto;
    padding: 2px 0 8px;
    flex: 1;
  }

  .node {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 1px 14px 1px 4px;
    font-size: 12px;
    color: #cbd5e1;
    white-space: nowrap;
    height: 22px;
  }

  .node.active {
    color: #cbd5e1;
    font-weight: 500;
  }

  .node.selected {
    background: rgba(94, 234, 212, 0.10);
  }

  .node.vcs.type-file .node-name { color: #b45309; }
  .node.vcs.type-folder .node-name { color: #b45309; }

  .indent { display: inline-block; flex-shrink: 0; }

  .caret-cell {
    width: 10px;
    color: #64748b;
    font-size: 9px;
    text-align: center;
    flex-shrink: 0;
  }

  .ficon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ficon.folder { color: #94a3b8; }
  .ficon.folder.libroot { color: #94a3b8; }

  .ficon.proj {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    background: linear-gradient(135deg, #5eead4, #38bdf8);
    color: #0f172a;
    font-size: 8px;
    font-weight: 800;
  }

  .file-ext {
    width: 14px;
    height: 14px;
    border-radius: 2px;
    font-size: 8px;
