---
/**
 * Pure HTML/CSS rendering of Sublime Text 3 with Slatewave applied. The
 * editor area uses Shiki with the same Slatewave theme the rest of the
 * site uses; everything else — title bar, tab navigation arrows, FOLDERS
 * sidebar, thin status bar, UNREGISTERED pill — is hand-built chrome
 * scoped to the Slatewave.sublime-color-scheme + Slatewave.sublime-theme.
 *
 * Sublime distinctives versus VSCode/JetBrains:
 *   - no activity bar — just sidebar + editor
 *   - centered file path in the title bar
 *   - "UNREGISTERED" pill in the top-right corner
 *   - minimal single-tab chrome with ◀ ▶ navigation
 *   - thin status bar, no breadcrumbs or diagnostic counts
 */

import { getHighlighter, slatewaveThemeName } from '~/lib/shiki';

const sample = `/**
 * Build-time GitHub metadata fetchers.
 *
 * Public-repo data only. Unauthenticated requests are rate-limited to
 * 60/hour per IP; set GITHUB_TOKEN in .env (or the CI environment) to
 * raise that to 5000/hour.
 *
 * Results are cached to \`node_modules/.cache/slatewave-github/\` with a
 * 30-minute TTL so dev hot-reloads don't burn API quota.
 */
import { mkdir, readFile, writeFile } from 'node:fs/promises';
import { join } from 'node:path';

const CACHE_DIR = join(process.cwd(), 'node_modules', '.cache', 'slatewave-github');
const TTL_MS = 30 * 60 * 1000;

export interface RepoMeta {
  stars: number;
  pushedAt: string;
  defaultBranch: string;
  openIssues: number;
  latestRelease: Release | null;
}

export interface Release {
  tag: string;
  name: string;
  publishedAt: string;
  url: string;
  body: string;
  isPrerelease: boolean;
}

const memory = new Map<string, Promise<unknown>>();

function cacheKey(parts: string[]): string {
  return parts.join('__').replace(/[^a-zA-Z0-9_]/g, '_');
}

async function readCache<T>(key: string): Promise<T | null> {
  try {
    const raw = await readFile(join(CACHE_DIR, \`\${key}.json\`), 'utf8');
    const parsed = JSON.parse(raw) as { data: T; at: number };
    if (Date.now() - parsed.at < TTL_MS) return parsed.data;
  } catch {
    /* no cache yet */
  }
  return null;
}`;

const highlighter = await getHighlighter();
const html = highlighter.codeToHtml(sample, {
  lang: 'typescript',
  theme: slatewaveThemeName,
});

const lineCount = sample.split('\n').length;
const lineNumbers = Array.from({ length: lineCount }, (_, i) => i + 1);

const minimapStyles = Array.from({ length: lineCount }, (_, i) => {
  const w = 28 + ((i * 17) % 60);
  const intensity = (i * 11) % 100;
  return `width:${w}%;opacity:${0.18 + intensity / 320}`;
});

interface Node {
  type: 'folder' | 'file' | 'root';
  name: string;
  open?: boolean;
  active?: boolean;
  indent: number;
}

const tree: Node[] = [
  { type: 'root', name: 'getslatewave', indent: 0, open: true },
  { type: 'folder', name: '.astro', indent: 1 },
  { type: 'folder', name: '.github', indent: 1 },
  { type: 'folder', name: '.idea', indent: 1 },
  { type: 'folder', name: '.vscode', indent: 1 },
  { type: 'folder', name: 'dist', indent: 1 },
  { type: 'folder', name: 'docs', indent: 1 },
  { type: 'folder', name: 'node_modules', indent: 1 },
  { type: 'folder', name: 'public', indent: 1 },
  { type: 'folder', name: 'src', indent: 1, open: true },
  { type: 'folder', name: 'components', indent: 2 },
  { type: 'folder', name: 'content', indent: 2 },
  { type: 'folder', name: 'layouts', indent: 2 },
  { type: 'folder', name: 'lib', indent: 2, open: true },
  { type: 'folder', name: 'fonts', indent: 3 },
  { type: 'file', name: 'analytics.ts', indent: 3 },
  { type: 'file', name: 'format.ts', indent: 3 },
  { type: 'file', name: 'github.ts', indent: 3, active: true },
  { type: 'file', name: 'monaco-theme.ts', indent: 3 },
  { type: 'file', name: 'og.ts', indent: 3 },
  { type: 'file', name: 'shiki.ts', indent: 3 },
  { type: 'file', name: 'slatewave-theme.json', indent: 3 },
  { type: 'folder', name: 'pages', indent: 2 },
  { type: 'folder', name: 'styles', indent: 2 },
  { type: 'file', name: 'content.config.ts', indent: 2 },
  { type: 'file', name: '.env', indent: 1 },
  { type: 'file', name: '.env.example', indent: 1 },
  { type: 'file', name: '.gitignore', indent: 1 },
  { type: 'file', name: 'astro.config.mjs', indent: 1 },
  { type: 'file', name: 'LICENSE', indent: 1 },
  { type: 'file', name: 'package.json', indent: 1 },
  { type: 'file', name: 'pnpm-lock.yaml', indent: 1 },
  { type: 'file', name: 'README.md', indent: 1 },
  { type: 'file', name: 'tsconfig.json', indent: 1 },
];
---

<figure class="st-preview" aria-label="Slatewave applied to Sublime Text 3">
  <div class="window">
    <header class="title-bar" aria-hidden="true">
      <div class="dots">
        <span class="dot dot-r"></span>
        <span class="dot dot-y"></span>
        <span class="dot dot-g"></span>
      </div>
      <div class="title-center">
        <svg class="title-icon" viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.7">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
        </svg>
        <span class="title-file">github.ts</span>
        <span class="title-sep">—</span>
        <span class="title-project">getslatewave</span>
      </div>
    </header>

    <div class="workbench">
      <aside class="sidebar">
        <div class="sidebar-head">FOLDERS</div>
        <div class="tree">
          {tree.map((n) => (
            <div class:list={['node', `type-${n.type}`, { active: n.active }]}>
              <span class="indent" style={`width:${n.indent * 14}px`}></span>
              {n.type === 'folder' && (
                <svg class="ficon folder" viewBox="0 0 24 24" width="12" height="12" fill="currentColor">
                  <path d="M3 6.5a1.5 1.5 0 0 1 1.5-1.5h4l2 2h9a1.5 1.5 0 0 1 1.5 1.5v9a1.5 1.5 0 0 1-1.5 1.5h-15A1.5 1.5 0 0 1 3 17.5z"/>
                </svg>
              )}
              {n.type === 'root' && (
                <Fragment>
                  <svg class="ficon folder" viewBox="0 0 24 24" width="12" height="12" fill="currentColor">
                    <path d="M3 6.5a1.5 1.5 0 0 1 1.5-1.5h4l2 2h9a1.5 1.5 0 0 1 1.5 1.5v9a1.5 1.5 0 0 1-1.5 1.5h-15A1.5 1.5 0 0 1 3 17.5z"/>
                  </svg>
                </Fragment>
              )}
              {n.type === 'file' && (
                <span class="file-spacer"></span>
              )}
              <span class="node-name">{n.name}</span>
              {n.type === 'root' && <span class="root-marker" aria-hidden="true">○</span>}
            </div>
          ))}
        </div>
      </aside>

      <section class="editor-pane">
        <div class="tab-bar">
          <div class="tab-nav">
            <span class="tab-arrow">◀</span>
            <span class="tab-arrow">▶</span>
          </div>
          <div class="tabs">
            <div class="tab active">
              <span class="tab-name">github.ts</span>
              <span class="tab-close">×</span>
            </div>
          </div>
          <div class="tab-actions">
            <span class="tab-action">+</span>
            <span class="tab-action">▾</span>
          </div>
        </div>

        <div class="editor">
          <div class="gutter" aria-hidden="true">
            {lineNumbers.map((n) => (
              <div class:list={['ln', { active: n === 58 }]}>{n}</div>
            ))}
          </div>
          <div class="code-wrap">
            <div class="code" set:html={html} />
            <div class="cursor-line" aria-hidden="true"></div>
          </div>
          <div class="minimap" aria-hidden="true">
            <div class="minimap-viewport"></div>
            {minimapStyles.map((s) => (
              <div class="mini-ln" style={s}></div>
            ))}
          </div>
        </div>
      </section>
    </div>

    <footer class="status-bar" aria-hidden="true">
      <div class="status-left">
        <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 6 15 12 9 18"/>
        </svg>
        <span class="status-cell">Line 58, Column 14</span>
      </div>
      <div class="status-right">
        <span class="status-cell">
          <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="6" cy="6" r="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="12" r="2"/>
            <path d="M6 8v8"/><path d="M8 6h6a4 4 0 0 1 4 4v0"/>
          </svg>
          main
          <span class="git-counter">2</span>
        </span>
        <span class="status-cell muted">Spaces: 2</span>
        <span class="status-cell">TypeScript</span>
      </div>
    </footer>
  </div>
</figure>

<style>
  .st-preview {
    margin: 0;
    padding: var(--space-8) var(--space-6);
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(15, 23, 42, 0.85), transparent 60%),
      var(--bg-default);
    border-radius: var(--radius-lg);
  }

  .window {
    background: #282c34;
    border: 1px solid #0f172a;
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 25px 60px -15px rgba(0, 0, 0, 0.6);
    font-family: var(--font-sans);
    color: #e2e8f0;
    display: flex;
    flex-direction: column;
    min-height: 580px;
  }

  /* Title bar — centered file path is the Sublime tell */
  .title-bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 8px 14px;
    background: #21252b;
    border-bottom: 1px solid #1a1f28;
    font-size: 11.5px;
    color: #cbd5e1;
  }

  .dots { display: inline-flex; gap: 8px; }
  .dot { width: 12px; height: 12px; border-radius: 50%; }
  .dot-r { background: #fb7185; }
  .dot-y { background: #fbbf24; }
  .dot-g { background: #5eead4; }

  .title-center {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    color: #cbd5e1;
  }

  .title-icon { color: #94a3b8; }
  .title-file { color: #e2e8f0; font-weight: 500; }
  .title-sep { color: #475569; }
  .title-project { color: #94a3b8; }

  .title-right {
    display: inline-flex;
    justify-content: flex-end;
  }

  .unregistered {
    color: #64748b;
    font-size: 10px;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  /* Workbench: sidebar | editor (no activity bar — Sublime keeps it simple) */
  .workbench {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    flex: 1;
    min-height: 0;
  }

  /* Sidebar — Sublime's FOLDERS pane */
  .sidebar {
    background: #21252b;
    border-right: 1px solid #1a1f28;
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
  }

  .sidebar-head {
    padding: 10px 16px 8px;
    text-transform: uppercase;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #5eead4;
  }

  .tree {
    overflow-y: auto;
    padding: 2px 0 8px;
    flex: 1;
  }

  .node {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 2px 14px 2px 8px;
    font-size: 12px;
    color: #cbd5e1;
    white-space: nowrap;
    height: 22px;
  }

  /* Sublime's selected file: full-width teal-tinted band, slightly more
     opaque than VSCode's row. */
  .node.active {
    background: rgba(94, 234, 212, 0.15);
    color: #5eead4;
  }

  .indent { display: inline-block; flex-shrink: 0; }

  .ficon {
    flex-shrink: 0;
  }

  .ficon.folder {
    color: #94a3b8;
  }

  .file-spacer {
    width: 12px;
    flex-shrink: 0;
  }

  .node-name {
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
  }

  .root-marker {
    color: #5eead4;
    font-size: 10px;
    margin-left: auto;
  }

  /* Editor pane */
  .editor-pane {
    display: flex;
    flex-direction: column;
    min-height: 0;
    min-width: 0;
  }

  /* Tab bar — Sublime's nav arrows + single tab + actions */
  .tab-bar {
    display: flex;
    align-items: stretch;
    background: #21252b;
    border-bottom: 1px solid #1a1f28;
    flex-shrink: 0;
    height: 30px;
  }

  .tab-nav {
    display: inline-flex;
    align-items: center;
    padding: 0 8px;
    gap: 6px;
    border-right: 1px solid #1a1f28;
    color: #475569;
    font-size: 11px;
  }

  .tab-arrow {
    cursor: default;
  }

  .tabs {
    display: flex;
    flex: 1;
    min-width: 0;
    overflow-x: auto;
  }

  .tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0 14px;
    font-size: 12px;
    color: #94a3b8;
    border-right: 1px solid #1a1f28;
    flex-shrink: 0;
    position: relative;
  }

  .tab.active {
    color: #e2e8f0;
    background: #282c34;
  }

  .tab.active::before {
    content: '';
    position: absolute;
    left: 0; right: 0; top: 0;
    height: 1px;
    background: #5eead4;
  }

  .tab-close {
    color: #475569;
    font-size: 12px;
  }

  .tab.active .tab-close { color: #94a3b8; }

  .tab-actions {
    display: inline-flex;
    align-items: center;
    padding: 0 12px;
    gap: 12px;
    border-left: 1px solid #1a1f28;
    color: #475569;
    font-size: 12px;
    margin-left: auto;
  }

  /* Editor body — line numbers | code | minimap (no breadcrumb above) */
  .editor {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) 90px;
    background: #282c34;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.55;
  }

  .gutter {
    color: #475569;
    text-align: right;
    padding: 10px 10px 10px 14px;
    user-select: none;
  }

  .ln {
    line-height: 1.55;
  }

  .ln.active {
    color: #5eead4;
    font-weight: 600;
    background: rgba(94, 234, 212, 0.06);
    padding: 0 4px;
    margin-right: -4px;
    border-radius: 2px;
  }

  .code-wrap {
    position: relative;
    overflow: hidden;
    padding: 10px 0 10px 10px;
  }

  .code :global(pre) {
    margin: 0;
    padding: 0;
    background: transparent !important;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.55;
  }

  /* Cursor line highlight — line 58 (offset by header padding + 57 lines) */
  .cursor-line {
    position: absolute;
    left: 0;
    right: 0;
    top: calc(10px + 57 * 1.55em);
    height: 1.55em;
    background: rgba(94, 234, 212, 0.05);
    border-top: 1px solid rgba(94, 234, 212, 0.15);
    border-bottom: 1px solid rgba(94, 234, 212, 0.15);
    pointer-events: none;
  }

  /* Minimap — Sublime's is bigger and more prominent than VSCode's */
  .minimap {
    background: #282c34;
    border-left: 1px solid #1e293b;
    padding: 10px 6px;
    display: flex;
    flex-direction: column;
    gap: 1px;
    overflow: hidden;
    position: relative;
  }

  .minimap-viewport {
    position: absolute;
    left: 0; right: 0;
    top: 14px;
    height: 26%;
    background: rgba(94, 234, 212, 0.10);
    border-top: 1px solid rgba(94, 234, 212, 0.25);
    border-bottom: 1px solid rgba(94, 234, 212, 0.25);
    pointer-events: none;
  }

  .mini-ln {
    height: 2px;
    background: #94a3b8;
    border-radius: 1px;
  }

  /* Status bar — thin and minimal, Sublime style */
  .status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #21252b;
    color: #cbd5e1;
    padding: 0 14px;
    height: 22px;
    font-size: 11px;
    border-top: 1px solid #1a1f28;
  }

  .status-left, .status-right {
    display: inline-flex;
    align-items: center;
    gap: 18px;
  }

  .status-left { gap: 8px; }
  .status-left svg { color: #5eead4; }

  .status-cell {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .status-cell.muted { color: #94a3b8; }

  .git-counter {
    color: #94a3b8;
    margin-left: 4px;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .editor { grid-template-columns: auto minmax(0, 1fr); }
    .minimap { display: none; }
  }

  @media (max-width: 720px) {
    .workbench { grid-template-columns: 200px minmax(0, 1fr); }
    .title-project { display: none; }
    .title-sep { display: none; }
  }

  @media (max-width: 540px) {
    .st-preview { padding: var(--space-4) var(--space-3); }
    .workbench { grid-template-columns: minmax(0, 1fr); }
    .sidebar { display: none; }
    .unregistered { display: none; }
    .status-cell:nth-child(n+3) { display: none; }
  }
</style>
