---
/**
 * Pure HTML/CSS rendering of the Slatewave Oh My Posh prompt.
 *
 * Layout:
 *   [teal: apple][teal: home][teal: path]  -> right-pointing chevron
 *   [rose: octocat + branch + counters]    -> overlaps teal's chevron
 *   [single dark chip: timer | cpu | clock, no gaps between]
 */
---

<figure class="omp-preview sw-frame" aria-label="Slatewave Oh My Posh prompt">
  <header class="chrome" aria-hidden="true">
    <span class="dot dot-r"></span>
    <span class="dot dot-y"></span>
    <span class="dot dot-g"></span>
    <span class="title">zsh — slatewave</span>
  </header>

  <div class="body">
    <p class="msg">no changes added to commit (use "git add" and/or "git commit -a")</p>

    <div class="prompt-row">
      <div class="segments">
        <span class="seg seg-apple">
          <svg viewBox="0 0 14 16" width="11" height="13" fill="currentColor" aria-hidden="true">
            <path d="M12.79 10.13c-.58 1.7-1.61 3.49-3.05 3.5-1.38.03-1.83-.83-3.42-.83-1.59 0-2.09.82-3.4.86-1.36.05-2.45-1.89-3.06-3.63-1.24-3.55.27-7.64 3.05-7.71 1.32-.03 2.57.89 3.37.89.8 0 2.32-1.1 3.9-.94.67.03 2.52.27 3.72 2.04-.1.06-2.22 1.3-2.2 3.88.03 3.09 2.7 4.12 2.73 4.13-.02.08-.43 1.48-1.41 3.01M7.13 1.43c.64-.78 1.72-1.35 2.61-1.39.12 1.04-.3 2.09-.92 2.84-.61.76-1.62 1.35-2.6 1.27-.13-1.03.37-2.1.91-2.72"/>
          </svg>
        </span>
        <span class="seg seg-teal path">
          <svg class="home" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 10.5L12 3l9 7.5V20a1 1 0 0 1-1 1h-5v-7h-6v7H4a1 1 0 0 1-1-1z"/>
          </svg>
          <span class="slash">/</span>
          <span>Dev</span>
          <span class="slash">/</span>
          <span>getslatewave</span>
        </span>

        <span class="seg seg-rose">
          <svg class="octocat" viewBox="0 0 16 16" width="12" height="12" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          <span>main</span>
          <span class="git-counter">↑11</span>
          <span class="git-counter">✏?3</span>
          <span class="git-counter">~1</span>
        </span>
      </div>

      <div class="rhs">
        <span class="rhs-part">
          <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 2h12M6 22h12M17 2v6a5 5 0 0 1-10 0V2M17 22v-6a5 5 0 0 0-10 0v6"/>
          </svg>
          0ms
        </span>
        <span class="rhs-part">
          <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="9"/>
            <circle cx="12" cy="12" r="2"/>
          </svg>
          CPU: <span class="strong">80.49%</span>
          <span class="pipe">│</span>
          RAM: <span class="strong">68/68GB</span>
          <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <ellipse cx="12" cy="5" rx="9" ry="3"/>
            <path d="M3 5v6c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/>
            <path d="M3 11v6c0 1.66 4.03 3 9 3s9-1.34 9-3v-6"/>
          </svg>
        </span>
        <span class="rhs-part">
          <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          1:43 AM
        </span>
      </div>
    </div>

    <div class="cmd-row">
      <span class="continuation" aria-hidden="true">↳)$</span>
      <span>git status</span>
    </div>

    <div class="prompt-row">
      <div class="segments">
        <span class="seg seg-apple">
          <svg viewBox="0 0 14 16" width="11" height="13" fill="currentColor" aria-hidden="true">
            <path d="M12.79 10.13c-.58 1.7-1.61 3.49-3.05 3.5-1.38.03-1.83-.83-3.42-.83-1.59 0-2.09.82-3.4.86-1.36.05-2.45-1.89-3.06-3.63-1.24-3.55.27-7.64 3.05-7.71 1.32-.03 2.57.89 3.37.89.8 0 2.32-1.1 3.9-.94.67.03 2.52.27 3.72 2.04-.1.06-2.22 1.3-2.2 3.88.03 3.09 2.7 4.12 2.73 4.13-.02.08-.43 1.48-1.41 3.01M7.13 1.43c.64-.78 1.72-1.35 2.61-1.39.12 1.04-.3 2.09-.92 2.84-.61.76-1.62 1.35-2.6 1.27-.13-1.03.37-2.1.91-2.72"/>
          </svg>
        </span>
        <span class="seg seg-teal path">
          <svg class="home" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 10.5L12 3l9 7.5V20a1 1 0 0 1-1 1h-5v-7h-6v7H4a1 1 0 0 1-1-1z"/>
          </svg>
          <span class="slash">/</span>
          <span>Dev</span>
          <span class="slash">/</span>
          <span>getslatewave</span>
        </span>

        <span class="seg seg-rose">
          <svg class="octocat" viewBox="0 0 16 16" width="12" height="12" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          <span>main</span>
          <span class="git-counter">↑11</span>
          <span class="git-counter">✏?3</span>
          <span class="git-counter">~1</span>
        </span>
      </div>

      <div class="rhs">
        <span class="rhs-part">
          <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 2h12M6 22h12M17 2v6a5 5 0 0 1-10 0V2M17 22v-6a5 5 0 0 0-10 0v6"/>
          </svg>
          0ms
        </span>
        <span class="rhs-part">
          <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="9"/>
            <circle cx="12" cy="12" r="2"/>
          </svg>
          CPU: <span class="strong">80.19%</span>
          <span class="pipe">│</span>
          RAM: <span class="strong">68/68GB</span>
          <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <ellipse cx="12" cy="5" rx="9" ry="3"/>
            <path d="M3 5v6c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/>
            <path d="M3 11v6c0 1.66 4.03 3 9 3s9-1.34 9-3v-6"/>
          </svg>
        </span>
        <span class="rhs-part">
          <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          1:43 AM
        </span>
      </div>
    </div>

    <div class="cmd-row">
      <span class="continuation" aria-hidden="true">↳)$</span>
      <span class="cursor" aria-hidden="true"></span>
    </div>
  </div>
</figure>

<style>
  .omp-preview {
    background: #1a1d23;
    overflow: hidden;
  }

  .chrome {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--border);
    background: var(--bg-raised);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-r { background: #fb7185; }
  .dot-y { background: #fbbf24; }
  .dot-g { background: #5eead4; }

  .title {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--fg-subtle);
    letter-spacing: 0.04em;
  }

  .body {
    padding: var(--space-4) var(--space-5);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.9;
    color: #e2e8f0;
    overflow-x: auto;
  }

  .msg {
    color: #e2e8f0;
    margin: 0 0 var(--space-2);
    white-space: nowrap;
  }

  .prompt-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    min-width: max-content;
  }

  .segments {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    flex-shrink: 0;
  }

  /* Teal segments: pentagon shape with right-point */
  .seg {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 18px 3px 12px;
    font-weight: 500;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 50%, calc(100% - 10px) 100%, 0 100%);
    min-height: 22px;
  }

  /* Apple segment: dark slate, hexagon (points on both sides).
     Highest z-index so its right-point paints over the teal that
     overlaps from the right. */
  .seg-apple {
    background: #282c34;
    color: #e2e8f0;
    padding: 3px 18px 3px 14px;
    clip-path: polygon(10px 0, calc(100% - 10px) 0, 100% 50%, calc(100% - 10px) 100%, 10px 100%, 0 50%);
    z-index: 3;
  }

  .seg-teal {
    background: #5eead4;
    color: #0f172a;
    z-index: 2;
  }

  /* Teal slides under apple's right-point. -10px margin lets teal's flat
     left fill the triangular gaps at top/bottom of apple's hexagon while
     apple's full body remains visible on top. */
  .seg-apple + .seg-teal {
    margin-left: -10px;
    padding-left: 18px;
  }

  .path {
    gap: 6px;
    padding-left: 14px;
  }

  .path .home {
    flex-shrink: 0;
    margin-right: 2px;
  }

  .path > span:not(.slash) {
    font-weight: 600;
  }

  .slash {
    opacity: 0.55;
    font-weight: 400;
  }

  /* Rose segment: hexagon with leftward indent AND rightward point.
     Negative margin makes it overlap the teal's right-point so the
     transition is continuous (no terminal-bg visible between them). */
  .seg-rose {
    background: #fb7185;
    color: #0f172a;
    padding: 3px 18px 3px 35px;
    margin-left: -25px;
    clip-path: polygon(10px 0, calc(100% - 10px) 0, 100% 50%, calc(100% - 10px) 100%, 10px 100%, 0 50%);
    gap: 6px;
    z-index: 1;
  }

  .octocat {
    flex-shrink: 0;
  }

  .git-counter {
    font-size: 10.5px;
    font-weight: 600;
    opacity: 0.85;
  }

  /* Right-hand side: one continuous dark bar with internal parts
     separated by subtle dividers. */
  .rhs {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    flex-shrink: 0;
    min-width: max-content;
    background: #282c34;
    border-radius: 4px;
    overflow: hidden;
    color: #e2e8f0;
    font-size: 11px;
    font-weight: 500;
    white-space: nowrap;
  }

  .rhs-part {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .rhs-part + .rhs-part {
    border-left: 1px solid rgba(255, 255, 255, 0.05);
  }

  .rhs-part svg {
    color: #cbd5e1;
    flex-shrink: 0;
  }

  .rhs-part .strong {
    color: #ffffff;
    font-weight: 600;
  }

  .rhs-part .pipe {
    color: #475569;
    margin: 0 2px;
  }

  /* Command / continuation row */
  .cmd-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: #e2e8f0;
    min-height: 20px;
  }

  .continuation {
    color: #64748b;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .cursor {
    display: inline-block;
    width: 8px;
    height: 1.15em;
    background: #fb7185;
    border-radius: 1px;
    animation: blink 1.1s steps(2, start) infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor { animation: none; }
  }
</style>
