---
/**
 * Pure HTML/CSS rendering of the Slatewave Oh My Posh prompt across
 * three OSes: macOS, Ubuntu, Windows. Each row has its own OS glyph,
 * realistic path, and stats — the rest of the chrome (home, path,
 * git, rhs chip) is shared so the palette reads identically across.
 */

interface Row {
  os: 'macos' | 'ubuntu' | 'windows';
  label: string;
  path: { first: string; second: string };
  timing: string;
  cpu: string;
  ram: string;
  clock: string;
  command?: string;
}

const rows: Row[] = [
  {
    os: 'macos',
    label: 'macOS',
    path: { first: 'Dev', second: 'getslatewave' },
    timing: '101ms',
    cpu: '80.49%',
    ram: '68/68GB',
    clock: '1:43 AM',
    command: 'git status',
  },
  {
    os: 'ubuntu',
    label: 'Ubuntu',
    path: { first: 'Dev', second: 'getslatewave' },
    timing: '124ms',
    cpu: '34.12%',
    ram: '14/16GB',
    clock: '1:44 AM',
    command: 'docker ps',
  },
  {
    os: 'windows',
    label: 'Windows',
    path: { first: 'Dev', second: 'getslatewave' },
    timing: '245ms',
    cpu: '54.80%',
    ram: '24/32GB',
    clock: '1:45 AM',
  },
];
---

<figure class="omp-preview sw-frame" aria-label="Slatewave Oh My Posh prompt on macOS, Ubuntu, and Windows">
  <header class="chrome" aria-hidden="true">
    <span class="dot dot-r"></span>
    <span class="dot dot-y"></span>
    <span class="dot dot-g"></span>
    <span class="title">zsh — slatewave</span>
  </header>

  <div class="body">
    {rows.map((row, i) => (
      <>
        <div class="prompt-row">
          <div class="segments">
            <span class={`seg seg-os seg-${row.os}`} aria-label={row.label}>
              {row.os === 'macos' && (
                <svg viewBox="0 0 24 24" width="15" height="17" fill="currentColor" aria-hidden="true">
                  <path d="M17.543 12.477c-.024-2.425 1.982-3.596 2.072-3.652-1.13-1.651-2.888-1.877-3.51-1.903-1.492-.151-2.915.878-3.672.878-.758 0-1.931-.855-3.175-.832-1.634.024-3.138.949-3.978 2.412-1.696 2.941-.433 7.3 1.222 9.689.808 1.17 1.77 2.484 3.035 2.437 1.218-.049 1.678-.788 3.148-.788 1.47 0 1.884.788 3.175.761 1.31-.024 2.141-1.193 2.946-2.366.931-1.358 1.314-2.673 1.338-2.74-.03-.013-2.567-.985-2.594-3.905m-2.406-7.17c.672-.816 1.128-1.95 1.003-3.079-.968.04-2.142.643-2.836 1.459-.623.725-1.168 1.88-1.02 2.988 1.08.083 2.18-.548 2.853-1.368"/>
                </svg>
              )}
              {row.os === 'ubuntu' && (
                <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
                  <path d="M17.61.455a3.41 3.41 0 0 0-3.41 3.41 3.41 3.41 0 0 0 3.41 3.41 3.41 3.41 0 0 0 3.41-3.41 3.41 3.41 0 0 0-3.41-3.41zM12.92.8C8.923.777 5.137 2.941 3.148 6.451a4.5 4.5 0 0 1 .26-.007 4.92 4.92 0 0 1 2.585.737A8.316 8.316 0 0 1 12.688 3.6 4.944 4.944 0 0 1 13.723.834 11.008 11.008 0 0 0 12.92.8zm9.226 4.994a4.915 4.915 0 0 1-1.918 2.246 8.36 8.36 0 0 1-.273 8.303 4.89 4.89 0 0 1 1.632 2.54 11.156 11.156 0 0 0 .559-13.089zM3.41 7.932A3.41 3.41 0 0 0 0 11.342a3.41 3.41 0 0 0 3.41 3.409 3.41 3.41 0 0 0 3.41-3.41 3.41 3.41 0 0 0-3.41-3.41zm2.027 7.866a4.908 4.908 0 0 1-2.915.358 11.1 11.1 0 0 0 7.991 6.698 11.234 11.234 0 0 0 2.422.249 4.879 4.879 0 0 1-.999-2.85 8.484 8.484 0 0 1-.836-.136 8.304 8.304 0 0 1-5.663-4.32zm11.405.928a3.41 3.41 0 0 0-3.41 3.41 3.41 3.41 0 0 0 3.41 3.41 3.41 3.41 0 0 0 3.41-3.41 3.41 3.41 0 0 0-3.41-3.41z"/>
                </svg>
              )}
              {row.os === 'windows' && (
                <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true">
                  <path d="M2 3.8l8.8-1.2v9.7H2V3.8zm0 9.7h8.8v9.7L2 21.9v-8.4zm9.8-10L23 2.2v11.1H11.8V3.5zm0 10h11.2V22.5l-11.2-1.6v-7.4z"/>
                </svg>
              )}
            </span>
            <span class="seg seg-teal path">
              <svg class="home" viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 10.5L12 3l9 7.5V20a1 1 0 0 1-1 1h-5v-7h-6v7H4a1 1 0 0 1-1-1z"/>
              </svg>
              <span class="slash">/</span>
              <span>{row.path.first}</span>
              <span class="slash">/</span>
              <span>{row.path.second}</span>
            </span>
            <span class="seg seg-rose">
              <svg class="octocat" viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
              </svg>
              <span>main</span>
              <span class="git-counter">↑11</span>
              <span class="git-counter">✏?3</span>
              <span class="git-counter">~1</span>
            </span>
          </div>

          <div class="rhs">
            <span class="rhs-part">
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M6 2h12M6 22h12M17 2v6a5 5 0 0 1-10 0V2M17 22v-6a5 5 0 0 0-10 0v6"/>
              </svg>
              {row.timing}
            </span>
            <span class="rhs-part">
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="9"/>
                <circle cx="12" cy="12" r="2"/>
              </svg>
              CPU: <span class="strong">{row.cpu}</span>
              <span class="pipe">│</span>
              RAM: <span class="strong">{row.ram}</span>
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <ellipse cx="12" cy="5" rx="9" ry="3"/>
                <path d="M3 5v6c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/>
                <path d="M3 11v6c0 1.66 4.03 3 9 3s9-1.34 9-3v-6"/>
              </svg>
            </span>
            <span class="rhs-part">
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              {row.clock}
            </span>
          </div>
        </div>

        <div class="cmd-row">
          <span class="continuation" aria-hidden="true">↳)$</span>
          {row.command ? <span>{row.command}</span> : <span class="cursor" aria-hidden="true"></span>}
        </div>
      </>
    ))}
  </div>
</figure>

<style>
  .omp-preview {
    background: #1a1d23;
    overflow: hidden;
  }

  .chrome {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: var(--sw-slate-chrome);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot-r { background: #fb7185; }
  .dot-y { background: #fbbf24; }
  .dot-g { background: #5eead4; }

  .title {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--sw-slate-400);
    letter-spacing: 0.04em;
  }

  .body {
    padding: var(--space-4) var(--space-5);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.9;
    color: #e2e8f0;
    overflow-x: auto;
  }

  .prompt-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    min-width: max-content;
  }

  .segments {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    flex-shrink: 0;
  }

  /* Base seg: pentagon with right-point chevron */
  .seg {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 18px 3px 12px;
    font-weight: 500;
    clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 50%, calc(100% - 10px) 100%, 0 100%);
    min-height: 22px;
  }

  /* OS segment: dark slate hexagon, points on both sides. Top z-index
     so its right-point paints over the teal segment that overlaps it.
     Chained .seg.seg-os selector for higher specificity than .seg
     alone — prevents the base pentagon clip-path from winning. */
  .seg.seg-os {
    background: #282c34;
    color: #e2e8f0;
    padding: 3px 18px 3px 14px;
    clip-path: polygon(10px 0, calc(100% - 10px) 0, 100% 50%, calc(100% - 10px) 100%, 10px 100%, 0 50%);
    z-index: 3;
  }

  .seg-teal {
    background: #5eead4;
    color: #0f172a;
    z-index: 2;
  }

  /* Teal overlaps the OS segment. -10px lets teal's flat left fill the
     triangular gaps at top/bottom of the OS hexagon. */
  .seg.seg-os + .seg.seg-teal {
    margin-left: -10px;
    padding-left: 18px;
  }

  .path {
    gap: 6px;
    padding-left: 14px;
  }

  .path .home {
    flex-shrink: 0;
    margin-right: 2px;
  }

  .path > span:not(.slash) {
    font-weight: 600;
  }

  .slash {
    opacity: 0.55;
    font-weight: 400;
  }

  /* Rose segment — left-arrow indent + right-point. -25px overlap with
     a matching +35 padding-left keeps the octocat clear of the teal
     chevron. */
  .seg-rose {
    background: #fb7185;
    color: #0f172a;
    padding: 3px 18px 3px 35px;
    margin-left: -25px;
    clip-path: polygon(10px 0, calc(100% - 10px) 0, 100% 50%, calc(100% - 10px) 100%, 10px 100%, 0 50%);
    gap: 6px;
    z-index: 1;
  }

  .octocat {
    flex-shrink: 0;
  }

  .git-counter {
    font-size: 10.5px;
    font-weight: 600;
    opacity: 0.85;
  }

  /* Right-hand side: one dark bar, three parts divided by thin rules */
  .rhs {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    flex-shrink: 0;
    min-width: max-content;
    background: #282c34;
    border-radius: 4px;
    overflow: hidden;
    color: #e2e8f0;
    font-size: 11px;
    font-weight: 500;
    white-space: nowrap;
  }

  .rhs-part {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .rhs-part + .rhs-part {
    border-left: 1px solid rgba(255, 255, 255, 0.05);
  }

  .rhs-part svg {
    color: #cbd5e1;
    flex-shrink: 0;
  }

  .rhs-part .strong {
    color: #ffffff;
    font-weight: 600;
  }

  .rhs-part .pipe {
    color: #475569;
    margin: 0 2px;
  }

  /* Command / continuation row */
  .cmd-row {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: #e2e8f0;
    min-height: 20px;
  }

  .continuation {
    color: #64748b;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .cursor {
    display: inline-block;
    width: 8px;
    height: 1.15em;
    background: #fb7185;
    border-radius: 1px;
    animation: blink 1.1s steps(2, start) infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor { animation: none; }
  }
</style>
