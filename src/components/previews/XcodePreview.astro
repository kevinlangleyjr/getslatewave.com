---
/**
 * Pure HTML/CSS rendering of Xcode 16 with Slatewave applied. The editor
 * area runs through Shiki (using the Slatewave TextMate theme) so the
 * Swift syntax colors are the real palette; everything else — title bar
 * status pill, navigator with icon strip + filter, jump bar with the
 * class-symbol breadcrumb, current-line band, minimap, and footer — is
 * hand-built chrome scoped to colors the .xccolortheme actually maps.
 *
 * Xcode distinctives versus the other IDE previews:
 *   - centered "Ready | <timestamp>" status pill in the title bar
 *   - navigator with a horizontal icon strip (project/find/issue/etc.)
 *   - jump bar instead of tabs: full path crumbs ending in "C SymbolName"
 *   - current-line highlight is a full-width band (not a thin underline)
 *     and the active line number is bold + accent-colored in the gutter
 *   - thin status bar with just "Line: N Col: N" on the right
 */

import { getHighlighter, slatewaveThemeName } from '~/lib/shiki';
import TrafficLightDots from './TrafficLightDots.astro';

const sample = `//
//  PaletteController.swift
//  Slatewave Theme Browser
//
//  Created by Kevin Langley on 05/03/2026.
//  Copyright © 2026 Slatewave. All rights reserved.
//

import SwiftUI
import OSLog

let SLATEWAVE_PREVIEW_WIDTH: CGFloat = 440
let SLATEWAVE_PREVIEW_HEIGHT: CGFloat = 485

final class PaletteController: NSViewController, ObservableObject {
    @Published var data: PaletteIdentifiableData?

    override func loadView() {
        // hand the view off to a SwiftUI host
        let rootView = PaletteRootView()
            .frame(width: SLATEWAVE_PREVIEW_WIDTH, height: SLATEWAVE_PREVIEW_HEIGHT)
            .environmentObject(self)

        let hostedView = NSHostingView(rootView: rootView)
        view = hostedView
    }

    /// Cancels the current preview session.
    /// Closes the preview UI without applying anything from the user.
    func cancel() {
        previewContext.cancelRequest(
            withError: NSError(domain: PreviewErrorDomain, code: PreviewError.userCanceled.rawValue))
    }

    func cancelWithFailed() {
        Logger.preview.error("cancelling preview context as failed")
        previewContext.cancelRequest(
            withError: NSError(domain: PreviewErrorDomain, code: PreviewError.failed.rawValue))
    }

    func cancelWithUserInteractionRequired() {
        Logger.preview.info("user interaction is required")
        previewContext.cancelRequest(
            withError: NSError(domain: PreviewErrorDomain, code: PreviewError.userInteractionRequired.rawValue))
    }
}`;

const highlighter = await getHighlighter();
const html = highlighter.codeToHtml(sample, {
  lang: 'swift',
  theme: slatewaveThemeName,
});

const lineCount = sample.split('\n').length;
const activeLine = 35; // matches the cursor line in the source screenshot
const lineNumbers = Array.from({ length: lineCount }, (_, i) => i + 1);

// Minimap stripe widths — pseudo-random but stable per build so the preview
// looks like real code density (longer lines visible, comments thinner) without
// us hand-authoring 50 widths.
const minimapStyles = Array.from({ length: lineCount }, (_, i) => {
  const w = 26 + ((i * 19) % 64);
  const intensity = (i * 13) % 100;
  return `width:${w}%;opacity:${0.18 + intensity / 320}`;
});

// Editor-only layout: no navigator sidebar in this preview, since the
// .xccolortheme file only paints the editor body. The breadcrumb shows
// the file's path but ends in "No Selection" — there's no selected
// symbol to highlight when the navigator isn't visible.
const breadcrumbs = [
  { name: 'Slatewave', kind: 'workspace' as const },
  { name: 'macOS', kind: 'folder' as const },
  { name: 'Palette', kind: 'folder' as const },
  { name: 'PaletteController.swift', kind: 'swift' as const },
  { name: 'No Selection', kind: 'none' as const },
];
---

<figure class="xcode-preview" aria-label="Slatewave applied to Xcode 16">
  <div class="window">
    <header class="title-bar" aria-hidden="true">
      <div class="title-left">
        <TrafficLightDots />
        <button class="ti-btn" type="button" aria-label="Toggle navigator">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.7">
            <line x1="4" y1="6" x2="20" y2="6"/>
            <line x1="4" y1="12" x2="20" y2="12"/>
            <line x1="4" y1="18" x2="20" y2="18"/>
            <circle cx="6" cy="6" r="0.8" fill="currentColor"/>
            <circle cx="6" cy="12" r="0.8" fill="currentColor"/>
            <circle cx="6" cy="18" r="0.8" fill="currentColor"/>
          </svg>
        </button>
        <button class="ti-btn ti-spark" type="button" aria-label="Coding intelligence">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8"/>
          </svg>
        </button>
      </div>
      <div class="title-status" role="status">
        <span class="status-headline">Ready</span>
        <span class="status-sep">|</span>
        <span class="status-time">Today at 14:42</span>
      </div>
      <div class="title-right">
        <button class="ti-btn" type="button" aria-label="Toggle inspector">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.7">
            <rect x="3" y="4" width="18" height="16" rx="2"/>
            <line x1="15" y1="4" x2="15" y2="20"/>
          </svg>
        </button>
      </div>
    </header>

    <div class="workbench">
      <section class="editor-pane">
        <div class="jump-bar" aria-hidden="true">
          <div class="jump-left">
            <span class="jb-icon" title="Show editor types">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/><rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/></svg>
            </span>
            <span class="jb-arrow">‹</span>
            <span class="jb-arrow">›</span>
          </div>
          <div class="jump-crumbs">
            {breadcrumbs.map((b, i) => (
              <>
                {i > 0 && <span class="jb-sep" aria-hidden="true">›</span>}
                <span class:list={['jb-crumb', `kind-${b.kind}`, { last: i === breadcrumbs.length - 1 }]}>
                  {b.kind === 'workspace' && (
                    <span class="jb-crumb-icon ws"><svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor"><rect x="3" y="3" width="18" height="18" rx="2"/></svg></span>
                  )}
                  {b.kind === 'folder' && (
                    <span class="jb-crumb-icon folder"><svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor"><path d="M3 6.5A1.5 1.5 0 0 1 4.5 5h4l2 2h9A1.5 1.5 0 0 1 21 8.5v9A1.5 1.5 0 0 1 19.5 19h-15A1.5 1.5 0 0 1 3 17.5z"/></svg></span>
                  )}
                  {b.kind === 'swift' && (
                    <span class="jb-crumb-icon swift" aria-hidden="true">
                      <svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor"><path d="M19.4 17.5c-2.3 1.4-5.4 1.6-8.6.5 1.4.3 2.8.1 4-.5-2-.4-3.9-1.6-5.6-3.6 1.6 1.1 3.4 1.8 5.2 2-2.4-1.5-4.4-3.7-6-6.4 2.7 2.7 5.7 4.4 8.7 5-.5-1.6-1.7-3.2-3.4-4.5 4.4 2.4 6.2 7.1 5.7 7.5z"/></svg>
                    </span>
                  )}
                  {b.kind === 'class' && <span class="jb-crumb-icon class">C</span>}
                  <span class:list={['jb-crumb-name', { none: b.kind === 'none' }]}>{b.name}</span>
                </span>
              </>
            ))}
          </div>
          <div class="jump-right">
            <span class="jb-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7"><polyline points="14 4 20 4 20 10"/><polyline points="10 20 4 20 4 14"/><line x1="20" y1="4" x2="14" y2="10"/><line x1="4" y1="20" x2="10" y2="14"/></svg>
            </span>
            <span class="jb-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.7"><line x1="5" y1="7" x2="19" y2="7"/><line x1="5" y1="12" x2="19" y2="12"/><line x1="5" y1="17" x2="19" y2="17"/></svg>
            </span>
            <span class="jb-icon" aria-hidden="true">+</span>
          </div>
        </div>

        <div class="editor">
          <div class="gutter" aria-hidden="true">
            {lineNumbers.map((n) => (
              <div class:list={['ln', { active: n === activeLine }]}>{n}</div>
            ))}
          </div>
          <div class="code-wrap">
            <div class="code" set:html={html} />
            <div class="cursor-band" aria-hidden="true"></div>
          </div>
          <div class="minimap" aria-hidden="true">
            <div class="minimap-viewport"></div>
            {minimapStyles.map((s) => (
              <div class="mini-ln" style={s}></div>
            ))}
          </div>
        </div>
      </section>
    </div>

    <footer class="status-bar" aria-hidden="true">
      <div class="status-left">
        <span class="status-pill"></span>
      </div>
      <div class="status-right">
        <span class="status-cell">Line: {activeLine}</span>
        <span class="status-sep-thin">·</span>
        <span class="status-cell">Col: 1</span>
        <span class="status-cell">
          <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="4" width="18" height="16" rx="2"/><line x1="15" y1="4" x2="15" y2="20"/></svg>
        </span>
      </div>
    </footer>
  </div>
</figure>

<style>
  .xcode-preview {
    margin: 0;
    padding: var(--space-8) var(--space-6);
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(15, 23, 42, 0.85), transparent 60%),
      var(--bg-default);
    border-radius: var(--radius-lg);

    /* macOS / Xcode chrome — these are *system* surfaces, not Slatewave.
       The .xccolortheme file only paints the editor body; everything else
       (title bar, navigator, jump bar, status bar, file icons) is whatever
       macOS dark mode + Xcode's vibrancy produce. We model those here so
       the preview honestly reflects what the theme actually controls.
       Sampled from a real Xcode screenshot in macOS dark mode. */
    --xc-chrome: #26282d;
    --xc-chrome-border: #181a1d;
    --xc-chrome-text: #d4d6dc;
    --xc-chrome-text-muted: #8d9098;
    --xc-chrome-text-faint: #62656c;
    --xc-pill: #1d1f24;
    --xc-system-blue: #4a9eff;
    --xc-swift-orange: #f05138;
  }

  @media (max-width: 720px) {
    .xcode-preview { padding: var(--space-4) var(--space-3); }
  }

  /* Window — system chrome wraps the whole preview. */
  .window {
    background: var(--xc-chrome);
    border: 1px solid var(--xc-chrome-border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.05) inset,
      0 25px 60px -15px rgba(0, 0, 0, 0.6);
    font-family: var(--font-sans);
    color: var(--xc-chrome-text);
    display: flex;
    flex-direction: column;
    min-height: 600px;
  }

  /* Title bar — macOS toolbar vibrancy. */
  .title-bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 8px 14px;
    background: var(--xc-chrome);
    border-bottom: 1px solid var(--xc-chrome-border);
    font-size: 11.5px;
    color: var(--xc-chrome-text-muted);
  }

  .title-left {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .ti-btn {
    background: transparent;
    border: 0;
    padding: 0;
    color: var(--xc-chrome-text-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    cursor: default;
  }

  .ti-spark { color: var(--xc-chrome-text-muted); }

  /* Centered "Ready | <timestamp>" pill — recessed, darker than chrome. */
  .title-status {
    justify-self: center;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 4px 18px;
    background: var(--xc-pill);
    border: 1px solid var(--xc-chrome-border);
    border-radius: 999px;
    font-size: 11px;
    min-width: 280px;
    justify-content: center;
    color: var(--xc-chrome-text-muted);
    box-shadow: inset 0 1px 0 rgba(0, 0, 0, 0.2);
  }

  .status-headline { color: var(--xc-chrome-text); font-weight: 500; }
  .status-sep { color: var(--xc-chrome-text-faint); }
  .status-time { color: var(--xc-chrome-text-muted); }

  .title-right {
    display: inline-flex;
    justify-content: flex-end;
  }

  /* Workbench — single column, editor-only. No navigator sidebar in
     this preview, since .xccolortheme files don't paint that surface. */
  .workbench {
    display: flex;
    flex: 1;
    min-height: 0;
  }

  /* Editor pane fills the workbench. */
  .editor-pane {
    display: flex;
    flex-direction: column;
    min-height: 0;
    min-width: 0;
    flex: 1;
    background: var(--xc-chrome);
  }

  /* Jump bar — system chrome (matches title bar / status bar). */
  .jump-bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: var(--xc-chrome);
    border-bottom: 1px solid var(--xc-chrome-border);
    height: 32px;
    flex-shrink: 0;
    font-size: 11.5px;
  }

  .jump-left, .jump-right {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--xc-chrome-text-muted);
  }

  .jb-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
  }

  .jb-arrow { font-size: 13px; color: var(--xc-chrome-text-muted); }

  .jump-crumbs {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    overflow: hidden;
    min-width: 0;
    color: var(--xc-chrome-text);
  }

  .jb-sep { color: var(--xc-chrome-text-faint); }

  .jb-crumb {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .jb-crumb.last .jb-crumb-name { color: #ffffff; }

  .jb-crumb-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 13px;
    height: 13px;
    border-radius: 2px;
    font-size: 8px;
    font-weight: 700;
    line-height: 1;
    flex-shrink: 0;
  }

  /* Breadcrumb icons mirror the navigator's system colors. */
  .jb-crumb-icon.ws { color: var(--xc-system-blue); }
  .jb-crumb-icon.folder { color: var(--xc-system-blue); }
  .jb-crumb-icon.swift { color: var(--xc-swift-orange); }
  /* The C class-symbol bubble — Xcode uses system blue here. */
  .jb-crumb-icon.class { background: var(--xc-system-blue); color: #ffffff; }

  /* Editor body — gutter | code (with current-line band) | minimap */
  .editor {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) 64px;
    background: var(--sw-slate-editor);
    flex: 1;
    min-height: 0;
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: 12px;
    /* Absolute line-height (not unitless) so the gutter — which uses a
       smaller 11px font for the line numbers — still produces rows the
       same height as the 12px code rows. Otherwise unitless 1.45
       inherits as a factor and the gutter drifts ~1.5px shorter per row. */
    line-height: calc(12px * 1.45);
    position: relative;
  }

  .gutter {
    color: var(--sw-slate-600);
    text-align: right;
    padding: 10px 10px 10px 8px;
    user-select: none;
    background: var(--sw-slate-editor);
    border-right: 1px solid transparent;
  }

  .ln {
    font-size: 11px;
  }

  /* Active line number — bold + accent — Xcode's tell. */
  .ln.active {
    color: var(--sw-sky-400);
    font-weight: 700;
  }

  .code-wrap {
    position: relative;
    overflow: hidden;
    padding: 10px 0;
  }

  .code :global(pre) {
    margin: 0;
    padding: 0 12px;
    background: transparent !important;
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.45;
    overflow: visible;
  }

  /* Current-line band — slate-800 at 50%, matching the actual value
     in DVTSourceTextCurrentLineHighlightColor (the .xccolortheme key).
     This is what real Xcode renders; the band reads as a subtle dark
     stripe on top of slate-editor. The active line *number* in the
     gutter (.ln.active) is what carries the visible blue tint. */
  .cursor-band {
    position: absolute;
    left: 0;
    right: 0;
    top: calc(10px + 34 * 1.45em);
    height: 1.45em;
    background: rgba(30, 41, 59, 0.5);
    pointer-events: none;
  }

  /* Bridge the band into the gutter (which sits in its own grid column). */
  .editor::before {
    content: '';
    position: absolute;
    left: 0;
    width: 56px;
    top: calc(10px + 34 * 1.45em);
    height: 1.45em;
    background: rgba(30, 41, 59, 0.5);
    pointer-events: none;
  }

  /* Minimap — narrow, low-contrast bars on the right. */
  .minimap {
    background: var(--sw-slate-editor);
    border-left: 1px solid var(--sw-slate-800);
    padding: 10px 6px;
    display: flex;
    flex-direction: column;
    gap: 1px;
    overflow: hidden;
    position: relative;
  }

  .minimap-viewport {
    position: absolute;
    left: 0; right: 0;
    top: 8px;
    height: 35%;
    background: rgba(148, 163, 184, 0.06);
    border-top: 1px solid rgba(148, 163, 184, 0.15);
    border-bottom: 1px solid rgba(148, 163, 184, 0.15);
    pointer-events: none;
  }

  .mini-ln {
    height: 2px;
    background: var(--sw-slate-400);
    border-radius: 1px;
  }

  /* Status bar — system chrome, not editor. Thin row with Line/Col. */
  .status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--xc-chrome);
    color: var(--xc-chrome-text-muted);
    padding: 0 12px;
    height: 24px;
    font-size: 11px;
    border-top: 1px solid var(--xc-chrome-border);
    flex-shrink: 0;
  }

  /* Bottom-left "Ready" indicator — system blue square. */
  .status-pill {
    display: inline-block;
    width: 9px;
    height: 9px;
    border-radius: 2px;
    background: var(--xc-system-blue);
  }

  .status-right {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .status-cell {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--xc-chrome-text-muted);
    font-family: var(--font-mono);
    font-size: 10.5px;
  }

  .status-sep-thin { color: var(--xc-chrome-text-faint); }

  /* "No Selection" trailing crumb — subdued, no icon. */
  .jb-crumb-name.none { color: var(--xc-chrome-text-muted); font-style: italic; }

  /* Responsive */
  @media (max-width: 900px) {
    .editor { grid-template-columns: 48px minmax(0, 1fr); }
    .minimap { display: none; }
    .gutter { padding-left: 4px; }
    .editor::before { width: 48px; }
  }

  @media (max-width: 720px) {
    .title-status { min-width: 200px; padding: 3px 12px; }
  }

  @media (max-width: 540px) {
    .title-status { min-width: 140px; }
    .status-time { display: none; }
    .status-sep { display: none; }
    .jump-right { display: none; }
  }
</style>
