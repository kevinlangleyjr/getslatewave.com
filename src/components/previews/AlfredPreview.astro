---
/**
 * Pure HTML/CSS rendering of Slatewave applied to Alfred. Mirrors the
 * .alfredappearance preset: slate-900 window, teal-300 selected title,
 * slate-300 unselected title, slate-500 subtext, slate-700 selected row.
 */

interface Row {
  title: string;
  subtitle?: string;
  iconBg: string;
  iconFg: string;
  icon: 'wave' | 'code' | 'hex' | 'terminal' | 'compass' | 'sun';
  hint: string;
  selected?: boolean;
}

const rows: Row[] = [
  {
    title: 'Slatewave for VSCode',
    subtitle: '/Applications/Visual Studio Code.app',
    iconBg: 'var(--sw-sky-400)',
    iconFg: 'var(--sw-slate-900)',
    icon: 'code',
    hint: '↵',
    selected: true,
  },
  {
    title: 'Slatewave for Obsidian',
    subtitle: '/Applications/Obsidian.app',
    iconBg: 'var(--sw-purple)',
    iconFg: 'var(--sw-slate-900)',
    icon: 'hex',
    hint: '⌘2',
  },
  {
    title: 'Slatewave for Helix',
    subtitle: '~/.config/helix/themes/slatewave.toml',
    iconBg: 'var(--sw-teal-300)',
    iconFg: 'var(--sw-slate-900)',
    icon: 'terminal',
    hint: '⌘3',
  },
  {
    title: 'Slatewave for WezTerm',
    subtitle: '~/.config/wezterm/colors/slatewave.toml',
    iconBg: 'var(--sw-slate-800)',
    iconFg: 'var(--sw-teal-300)',
    icon: 'wave',
    hint: '⌘4',
  },
  {
    title: 'Slatewave for Raycast',
    subtitle: 'Theme Studio · Slatewave.json',
    iconBg: 'var(--sw-rose-400)',
    iconFg: 'var(--sw-slate-900)',
    icon: 'compass',
    hint: '⌘5',
  },
  {
    title: 'Slatewave for Ghostty',
    subtitle: '~/.config/ghostty/themes/Slatewave',
    iconBg: 'var(--sw-amber-400)',
    iconFg: 'var(--sw-slate-900)',
    icon: 'sun',
    hint: '⌘6',
  },
];
---

<figure class="alfred-preview" aria-label="Slatewave applied to Alfred">
  <div class="window">
    <div class="search">
      <span class="query">wave</span>
      <span class="caret" aria-hidden="true"></span>
    </div>

    <div class="results">
      {rows.map((row) => (
        <div class:list={['row', { selected: row.selected }]}>
          <span class="icon" style={`background:${row.iconBg};color:${row.iconFg}`} aria-hidden="true">
            {row.icon === 'wave' && (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 12c2-4 4-4 6 0s4 4 6 0 4-4 6 0"/>
              </svg>
            )}
            {row.icon === 'code' && (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="8 6 3 12 8 18"/>
                <polyline points="16 6 21 12 16 18"/>
              </svg>
            )}
            {row.icon === 'hex' && (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 21 7 21 17 12 22 3 17 3 7 12 2"/>
              </svg>
            )}
            {row.icon === 'terminal' && (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 8 10 12 6 16"/>
                <line x1="13" y1="17" x2="18" y2="17"/>
              </svg>
            )}
            {row.icon === 'compass' && (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"/>
                <polygon points="15 9 11 13 9 15 13 11"/>
              </svg>
            )}
            {row.icon === 'sun' && (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="4"/>
                <line x1="12" y1="3" x2="12" y2="6"/>
                <line x1="12" y1="18" x2="12" y2="21"/>
                <line x1="3" y1="12" x2="6" y2="12"/>
                <line x1="18" y1="12" x2="21" y2="12"/>
                <line x1="5.6" y1="5.6" x2="7.7" y2="7.7"/>
                <line x1="16.3" y1="16.3" x2="18.4" y2="18.4"/>
                <line x1="5.6" y1="18.4" x2="7.7" y2="16.3"/>
                <line x1="16.3" y1="7.7" x2="18.4" y2="5.6"/>
              </svg>
            )}
          </span>
          <div class="text">
            <div class="title">{row.title}</div>
            {row.subtitle && <div class="subtitle">{row.subtitle}</div>}
          </div>
          <span class="hint">{row.hint}</span>
        </div>
      ))}
    </div>
  </div>
</figure>

<style>
  .alfred-preview {
    margin: 0;
    padding: var(--space-6);
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(15, 23, 42, 0.85), transparent 60%),
      var(--bg-default);
    border-radius: var(--radius-lg);
  }

  .window {
    max-width: 640px;
    margin: 0 auto;
    background: rgba(40, 44, 52, 0.92);
    border: 1px solid var(--sw-slate-800);
    border-radius: 14px;
    box-shadow:
      0 25px 60px -15px rgba(0, 0, 0, 0.6),
      0 0 0 1px rgba(255, 255, 255, 0.04) inset;
    backdrop-filter: blur(20px);
    overflow: hidden;
    font-family: var(--font-sans);
    color: var(--sw-slate-300);
  }

  .search {
    display: flex;
    align-items: center;
    padding: 22px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .query {
    font-size: 36px;
    font-weight: 300;
    color: var(--sw-slate-200);
    letter-spacing: -0.01em;
    line-height: 1;
    background: rgba(94, 234, 212, 0.12);
    padding: 0 4px;
    border-radius: 2px;
  }

  .caret {
    display: inline-block;
    width: 2px;
    height: 38px;
    background: var(--sw-teal-300);
    margin-left: 4px;
    animation: alfred-blink 1.1s steps(2, start) infinite;
  }

  @keyframes alfred-blink {
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .caret { animation: none; }
  }

  .results {
    padding: 6px 0;
  }

  .row {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 14px;
    padding: 8px 18px;
    margin: 0 6px;
    border-radius: 6px;
  }

  .row.selected {
    background: rgba(51, 65, 85, 0.7);
  }

  .icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .text {
    min-width: 0;
  }

  .title {
    color: var(--sw-slate-300);
    font-size: 18px;
    font-weight: 400;
    letter-spacing: -0.01em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .row.selected .title {
    color: var(--sw-teal-300);
  }

  .subtitle {
    color: var(--sw-slate-500);
    font-size: 12px;
    font-family: var(--font-mono);
    margin-top: 2px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .hint {
    color: var(--sw-slate-600);
    font-size: 13px;
    font-family: var(--font-mono);
    flex-shrink: 0;
  }

  .row.selected .hint {
    color: var(--sw-teal-300);
  }

  @media (max-width: 540px) {
    .alfred-preview { padding: var(--space-3); }
    .search { padding: 16px 18px; }
    .query { font-size: 28px; }
    .caret { height: 30px; }
    .title { font-size: 16px; }
    .subtitle { font-size: 11px; }
    .icon { width: 32px; height: 32px; border-radius: 7px; }
    .icon svg { width: 18px; height: 18px; }
  }
</style>
