---
/**
 * Pure HTML/CSS rendering of `lsd -la --git --tree --depth=2` with
 * Slatewave applied.
 *
 * Every column maps to a slot in lsd-slatewave/colors.yaml, so the
 * preview puts each role on screen without making the user run lsd
 * themselves.
 *
 * LSD draws Nerd Font glyphs to the left of each name. Browsers can't be
 * relied on to have a Nerd Font installed, so we substitute inline SVG
 * icons whose silhouettes match the most common LSD glyphs (folders,
 * dot-folders, git/github specials, language-specific file types, etc.).
 *
 * File and folder names render in the default text color (slate-200).
 * LSD leaves type-based name colors to LS_COLORS, which is shipped
 * separately from colors.yaml — without an LS_COLORS set, all names
 * render uniformly. Differentiation lives entirely in the icon color.
 */

import TerminalChrome from './TerminalChrome.astro';

type IconKey =
  | 'folder' | 'folder-hidden'
  | 'file' | 'config'
  | 'env' | 'env-example'
  | 'git' | 'github' | 'gitignore'
  | 'vscode' | 'idea'
  | 'apple'
  | 'ts' | 'js' | 'json' | 'yaml' | 'md' | 'license' | 'astro'
  | 'image' | 'webmanifest'
  | 'link' | 'exec';

type SizeKind = 'none' | 'small' | 'medium' | 'large';
type DateKind = 'hour-old' | 'day-old' | 'older';
type GitKind = 'unmodified' | 'ignored' | 'modified' | 'added' | 'deleted' | 'renamed' | 'untracked';

interface Row {
  git: GitKind;
  ftype: 'd' | '-' | 'l';
  perms: string; // 9 chars: rwxrwxrwx (with - for absent bits)
  size: string;
  sizeKind: SizeKind;
  date: string;
  dateKind: DateKind;
  prefix: string; // tree-edge prefix string, e.g. '├── ' or '│   └── '
  icon: IconKey;
  name: string;
}

const u = 'kevin.langleyjr';
const g = 'staff';

const rows: Row[] = [
  // Root entries (depth 1)
  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: '512 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '── ',     icon: 'folder',         name: '.' },

  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: '347 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '├── ',    icon: 'env-example',    name: '.env.example' },
  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: '384 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '├── ',    icon: 'git',            name: '.git' },

  // .git children (depth 2)
  { git: 'ignored',    ftype: '-', perms: 'rw-r--r--', size: '316 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'config',         name: 'config' },
  { git: 'ignored',    ftype: '-', perms: 'rw-r--r--', size: ' 73 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:26 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'file',           name: 'description' },
  { git: 'ignored',    ftype: '-', perms: 'rw-r--r--', size: ' 21 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:26 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'file',           name: 'HEAD' },
  { git: 'ignored',    ftype: 'd', perms: 'rwxr-xr-x', size: '512 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'folder',         name: 'hooks' },
  { git: 'ignored',    ftype: '-', perms: 'rw-r--r--', size: '8.8 KB', sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'file',           name: 'index' },
  { git: 'ignored',    ftype: 'd', perms: 'rwxr-xr-x', size: ' 96 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:26 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'folder',         name: 'info' },
  { git: 'ignored',    ftype: 'd', perms: 'rwxr-xr-x', size: '128 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'folder',         name: 'logs' },
  { git: 'ignored',    ftype: 'd', perms: 'rwxr-xr-x', size: '128 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:26 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'folder',         name: 'objects' },
  { git: 'ignored',    ftype: '-', perms: 'rw-r--r--', size: '112 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'file',           name: 'packed-refs' },
  { git: 'ignored',    ftype: 'd', perms: 'rwxr-xr-x', size: '160 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:26 2026', dateKind: 'older', prefix: '│   └── ', icon: 'folder',         name: 'refs' },

  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: ' 96 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '├── ',    icon: 'github',         name: '.github' },
  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: ' 96 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   └── ', icon: 'folder',         name: 'workflows' },

  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: '264 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '├── ',    icon: 'gitignore',      name: '.gitignore' },

  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: '128 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '├── ',    icon: 'vscode',         name: '.vscode' },
  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: ' 87 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'json',           name: 'extensions.json' },
  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: '207 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   └── ', icon: 'json',           name: 'launch.json' },

  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: '626 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '├── ',    icon: 'js',             name: 'astro.config.mjs' },

  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: ' 96 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '├── ',    icon: 'folder',         name: 'docs' },
  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: ' 96 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   └── ', icon: 'folder',         name: 'roadmap' },

  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: '479 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '├── ',    icon: 'license',        name: 'LICENSE' },
  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: '871 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '├── ',    icon: 'json',           name: 'package.json' },
  { git: 'ignored',    ftype: '-', perms: 'rw-r--r--', size: '139 KB', sizeKind: 'medium', date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '├── ',    icon: 'yaml',           name: 'pnpm-lock.yaml' },

  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: '256 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '├── ',    icon: 'folder',         name: 'public' },
  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: ' 16 KB', sizeKind: 'medium', date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'image',          name: 'apple-touch-icon.png' },
  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: '192 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'folder',         name: 'brand' },
  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: '2.4 KB', sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'image',          name: 'favicon-32.png' },
  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: ' 24 KB', sizeKind: 'medium', date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'image',          name: 'favicon.png' },
  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: ' 20 KB', sizeKind: 'medium', date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'image',          name: 'icon-192.png' },
  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: '552 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   └── ', icon: 'webmanifest',    name: 'site.webmanifest' },

  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: '2.7 KB', sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '├── ',    icon: 'md',             name: 'README.md' },

  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: '288 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '├── ',    icon: 'folder',         name: 'src' },
  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: '224 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'folder',         name: 'components' },
  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: '128 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'folder',         name: 'content' },
  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: '2.7 KB', sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'ts',             name: 'content.config.ts' },
  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: '128 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'folder',         name: 'layouts' },
  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: '288 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'folder',         name: 'lib' },
  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: '320 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   ├── ', icon: 'folder',         name: 'pages' },
  { git: 'unmodified', ftype: 'd', perms: 'rwxr-xr-x', size: '192 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '│   └── ', icon: 'folder',         name: 'styles' },

  { git: 'unmodified', ftype: '-', perms: 'rw-r--r--', size: '201 B',  sizeKind: 'small',  date: 'Mon Apr 27 00:09:29 2026', dateKind: 'older', prefix: '└── ',    icon: 'json',           name: 'tsconfig.json' },
];

const gitColor: Record<GitKind, string> = {
  unmodified: 'var(--sw-slate-500)',
  ignored: 'var(--sw-slate-600)',
  modified: 'var(--sw-amber-400)',
  added: 'var(--sw-teal-300)',
  deleted: 'var(--sw-rose-400)',
  renamed: 'var(--sw-sky-300)',
  untracked: 'var(--sw-teal-200)',
};

const gitChar: Record<GitKind, string> = {
  unmodified: '.',
  ignored: '!',
  modified: 'M',
  added: 'A',
  deleted: 'D',
  renamed: 'R',
  untracked: '?',
};

const permClass = (c: string): string => {
  if (c === 'r') return 'p p-r';
  if (c === 'w') return 'p p-w';
  if (c === 'x') return 'p p-x';
  if (c === 's' || c === 't') return 'p p-s';
  return 'p p-dash';
};
---

<figure class="lsd-preview" aria-label="Slatewave applied to lsd">
  <div class="window">
    <TerminalChrome title="zsh in getslatewave.com" />

    <div class="body">
      <div class="prompt-line">
        <span class="prompt-cwd">~/Development/getslatewave</span>
        <span class="prompt-branch">⎇ main</span>
        <span class="prompt-arrow">❯</span>
        <span class="prompt-cmd">lsd</span>
        <span class="prompt-flag">-la</span>
        <span class="prompt-flag">--git</span>
        <span class="prompt-flag">--tree</span>
        <span class="prompt-flag">--depth=2</span>
      </div>

      <div class="listing" role="table" aria-label="lsd output">
        {rows.map((row) => (
          <div class="row" role="row">
            <span class="col col-git" style={`color:${gitColor[row.git]}`}>{gitChar[row.git]}</span>
            <span class="col col-perms">
              <span class:list={['ft', `ft-${row.ftype}`]}>{row.ftype}</span>
              {row.perms.split('').map((c) => <span class={permClass(c)}>{c}</span>)}
            </span>
            <span class="col col-user">{u}</span>
            <span class="col col-group">{g}</span>
            <span class:list={['col', 'col-size', `size-${row.sizeKind}`]}>{row.size}</span>
            <span class:list={['col', 'col-date', `date-${row.dateKind}`]}>{row.date}</span>
            <span class="col col-name">
              <span class="tree-edge">{row.prefix}</span>
              <span class:list={['ficon', `icon-${row.icon}`]}>
                {row.icon === 'folder' && <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M2 4.5A1.5 1.5 0 0 1 3.5 3h2.379a1.5 1.5 0 0 1 1.06.44L8 4.5h4.5A1.5 1.5 0 0 1 14 6v5.5A1.5 1.5 0 0 1 12.5 13h-9A1.5 1.5 0 0 1 2 11.5z"/></svg>}
                {row.icon === 'folder-hidden' && <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M2 4.5A1.5 1.5 0 0 1 3.5 3h2.379a1.5 1.5 0 0 1 1.06.44L8 4.5h4.5A1.5 1.5 0 0 1 14 6v5.5A1.5 1.5 0 0 1 12.5 13h-9A1.5 1.5 0 0 1 2 11.5z"/></svg>}
                {row.icon === 'file' && <svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M3 2h6.5L13 5.5V14H3z"/><polyline points="9 2 9 6 13 6"/></svg>}
                {row.icon === 'config' && <svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M3 2h6.5L13 5.5V14H3z"/><polyline points="9 2 9 6 13 6"/><line x1="5" y1="9" x2="11" y2="9"/><line x1="5" y1="11" x2="9" y2="11"/></svg>}
                {row.icon === 'env' && <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33h.05a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51h.05a1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v.05a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>}
                {row.icon === 'env-example' && <svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M3 2h6.5L13 5.5V14H3z"/><polyline points="9 2 9 6 13 6"/></svg>}
                {row.icon === 'git' && <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="12" r="2"/><path d="M6 8v8"/><path d="M8 6h6a4 4 0 0 1 4 4v0"/></svg>}
                {row.icon === 'github' && <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>}
                {row.icon === 'gitignore' && <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="6" cy="6" r="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="12" r="2"/><path d="M6 8v8"/><path d="M8 6h6a4 4 0 0 1 4 4v0"/><line x1="3" y1="3" x2="21" y2="21" stroke-linecap="round"/></svg>}
                {row.icon === 'vscode' && <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><path d="M17 1.5L7.5 8.7 3 5.3v13.4l4.5-3.4L17 22.5 21 20.5V3.5L17 1.5zM9 12L17 5.7v12.6L9 12z"/></svg>}
                {row.icon === 'idea' && <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1V18h6v-1.2c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2z"/></svg>}
                {row.icon === 'apple' && <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor"><path d="M17.543 12.477c-.024-2.425 1.982-3.596 2.072-3.652-1.13-1.651-2.888-1.877-3.51-1.903-1.492-.151-2.915.878-3.672.878s-1.931-.855-3.175-.832c-1.634.024-3.138.949-3.978 2.412-1.696 2.941-.433 7.3 1.222 9.689.808 1.17 1.77 2.484 3.035 2.437 1.218-.049 1.678-.788 3.148-.788s1.884.788 3.175.761c1.31-.024 2.141-1.193 2.946-2.366.931-1.358 1.314-2.673 1.338-2.74-.03-.013-2.567-.985-2.594-3.905m-2.406-7.17c.672-.816 1.128-1.95 1.003-3.079-.968.04-2.142.643-2.836 1.459-.623.725-1.168 1.88-1.02 2.988 1.08.083 2.18-.548 2.853-1.368"/></svg>}
                {row.icon === 'ts' && <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><rect x="1" y="1" width="14" height="14" rx="2"/><text x="8" y="11" text-anchor="middle" font-family="ui-sans-serif,system-ui" font-size="6.5" font-weight="800" fill="var(--sw-slate-900)">TS</text></svg>}
                {row.icon === 'js' && <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><rect x="1" y="1" width="14" height="14" rx="2"/><text x="8" y="11" text-anchor="middle" font-family="ui-sans-serif,system-ui" font-size="6.5" font-weight="800" fill="var(--sw-slate-900)">JS</text></svg>}
                {row.icon === 'json' && <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor"><rect x="1" y="1" width="14" height="14" rx="2"/><text x="8" y="11" text-anchor="middle" font-family="ui-monospace,monospace" font-size="7" font-weight="800" fill="var(--sw-slate-900)">{`{}`}</text></svg>}
