---
import { getHighlighter, slatewaveThemeName } from '~/lib/shiki';
import type { BundledLanguage } from 'shiki';
import TerminalChrome from './TerminalChrome.astro';

interface Props {
  code: string;
  language: string;
  label?: string;
  showChrome?: boolean;
  lineNumbers?: boolean;
}

const { code, language, label, showChrome = true, lineNumbers = false } = Astro.props;

const highlighter = await getHighlighter();
const loadedLangs = highlighter.getLoadedLanguages();
const lang = (loadedLangs.includes(language as BundledLanguage) ? language : 'text') as BundledLanguage | 'text';

if (lang !== 'text' && !loadedLangs.includes(lang)) {
  await highlighter.loadLanguage(lang as BundledLanguage);
}

const html = highlighter.codeToHtml(code.trimEnd(), {
  lang,
  theme: slatewaveThemeName,
});
---

<figure class:list={['code-preview', 'sw-frame', { 'has-line-numbers': lineNumbers }]}>
  {showChrome && (
    <TerminalChrome>
      {(label || language) && <span slot="trailing" class="label">{label ?? language}</span>}
    </TerminalChrome>
  )}
  <div class="code-body" set:html={html} />
</figure>

<style>
  .code-preview {
    background: var(--sw-slate-editor);
  }

  .label {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--sw-slate-400);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .code-body :global(pre) {
    margin: 0;
    padding: var(--space-5);
    overflow-x: auto;
    font-size: var(--fs-sm);
    line-height: var(--lh-normal);
    background: transparent !important;
  }

  @media (max-width: 640px) {
    .code-body :global(pre) {
      padding: var(--space-3) var(--space-4);
      font-size: var(--fs-xs);
    }
  }

  .code-body :global(code) {
    font-family: var(--font-mono);
  }

  .has-line-numbers .code-body :global(code) {
    counter-reset: step;
    counter-increment: step 0;
  }

  .has-line-numbers .code-body :global(.line)::before {
    content: counter(step);
    counter-increment: step;
    display: inline-block;
    width: 2ch;
    margin-right: 1.25rem;
    text-align: right;
    color: var(--sw-slate-500, rgba(148, 163, 184, 0.45));
  }
</style>
