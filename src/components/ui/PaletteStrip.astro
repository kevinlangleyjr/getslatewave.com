---
interface Swatch {
  name: string;
  value: string;
  role?: string;
}

interface Props {
  swatches?: Swatch[];
}

const defaultSwatches: Swatch[] = [
  { name: 'Slate 900', value: '#0f172a', role: 'bg.inset' },
  { name: 'Slate 800', value: '#1e293b', role: 'bg.elevated' },
  { name: 'Slate Chrome', value: '#21252b', role: 'bg.raised' },
  { name: 'Slate Editor', value: '#282c34', role: 'bg.base' },
  { name: 'Slate 500', value: '#64748b', role: 'fg.faint' },
  { name: 'Slate 300', value: '#cbd5e1', role: 'fg.muted' },
  { name: 'Slate 200', value: '#e2e8f0', role: 'fg.default' },
  { name: 'Teal 300', value: '#5eead4', role: 'accent — signature' },
  { name: 'Teal 200', value: '#99f6e4', role: 'syntax.string' },
  { name: 'Sky 400', value: '#38bdf8', role: 'syntax.keyword' },
  { name: 'Rose 400', value: '#fb7185', role: 'syntax.constant' },
  { name: 'Purple', value: '#b388ff', role: 'syntax.language' },
  { name: 'Amber 400', value: '#fbbf24', role: 'syntax.escape' },
];

const { swatches = defaultSwatches } = Astro.props;
---

<ul class="palette" aria-label="Slatewave palette">
  {
    swatches.map((s) => (
      <li>
        <span class="chip" style={`background: ${s.value}`} aria-hidden="true" />
        <span class="meta">
          <span class="name">{s.name}</span>
          {s.role && <span class="role">{s.role}</span>}
          <span class="value">{s.value}</span>
        </span>
      </li>
    ))
  }
</ul>

<style>
  .palette {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li {
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: var(--space-3);
    align-items: center;
    padding: var(--space-3);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }

  .chip {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
  }

  .meta {
    display: grid;
    gap: 2px;
    font-size: var(--fs-xs);
  }

  .name {
    font-weight: 600;
    color: var(--fg-default);
    font-size: var(--fs-sm);
  }

  .role {
    color: var(--fg-subtle);
    font-family: var(--font-mono);
  }

  .value {
    color: var(--fg-muted);
    font-family: var(--font-mono);
  }
</style>
